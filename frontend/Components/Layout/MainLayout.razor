@inherits LayoutComponentBase

<MudThemeProvider Theme="_currentTheme" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Fixed="true" Class="lsmch-appbar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        
        <div class="d-flex align-center ml-4">
            <img src="/images/LSMCH.png" class="logo-img" alt="LSMCH Logo" />
            <div class="d-none d-sm-flex flex-column">
                <MudText Typo="Typo.h6" Class="lsmch-title mb-n1">LABORATORIO DE SUELOS</MudText>
                <MudText Typo="Typo.caption" Class="lsmch-subtitle font-weight-bold" Style="color: #64748b;">Y MATERIALES DE CHIRIQUÍ</MudText>
            </div>
        </div>

        <MudSpacer />
        
        <div class="d-none d-md-flex align-center mr-6 px-4 py-2" style="border-radius: 24px; background: rgba(30,58,138,0.06); border: 1px solid rgba(30,58,138,0.1);">
            <img src="/images/UTP.png" style="height: 38px;" alt="UTP Logo" />
            <div class="ml-3 d-flex flex-column">
                <MudText Typo="Typo.caption" Class="font-weight-bold" Style="line-height: 1; font-size: 0.65rem; color: #1e3a8a; letter-spacing: 0.5px;">UNIVERSIDAD</MudText>
                <MudText Typo="Typo.caption" Class="font-weight-bold" Style="line-height: 1; font-size: 0.65rem; color: #1e3a8a; letter-spacing: 0.5px;">TECNOLÓGICA DE PANAMÁ</MudText>
            </div>
        </div>

        <MudTooltip Text="Alternar Modo Oscuro">
            <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Class="rounded-lg shadow-sm" OnClick="@((e) => DarkModeToggle())" />
        </MudTooltip>
        
        <MudMenu Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Primary" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Class="ml-4">
            <MudMenuItem Icon="@Icons.Material.Filled.Person" IconColor="Color.Primary">Mi Perfil</MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.Settings" IconColor="Color.Secondary">Ajustes</MudMenuItem>
            <MudDivider />
            <MudMenuItem Icon="@Icons.Material.Filled.Logout" IconColor="Color.Error">Cerrar Sesión</MudMenuItem>
        </MudMenu>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="0" Fixed="true" Width="280px" Variant="@(_drawerOpen ? DrawerVariant.Responsive : DrawerVariant.Mini)">
        <div class="pa-5 d-flex justify-center mb-4 sidebar-header">
            <MudText Typo="Typo.overline" Style="color: rgba(255,255,255,0.7); letter-spacing: 2.5px; font-weight: 800; font-size: 0.75rem;">PANEL DE CONTROL</MudText>
        </div>
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="pt-16 px-4 pb-4">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
            <div class="animate__animated animate__fadeIn">
                @Body
            </div>
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = true;
    bool _isDarkMode = false;

    private void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void DarkModeToggle()
    {
        _isDarkMode = !_isDarkMode;
    }

    private MudTheme _currentTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#1e3a8a",       // Deep Laboratory Blue
            Secondary = "#3b82f6",     // Vibrant Royal Blue
            AppbarBackground = "rgba(255, 255, 255, 0.95)",
            Background = "#f8fafc",
            DrawerBackground = "#0f172a",
            DrawerText = "#f8fafc",
            DrawerIcon = "rgba(255,255,255, 0.65)",
            Surface = "#ffffff",
            TextPrimary = "#0f172a",
            TextSecondary = "#475569",
            ActionDefault = "#1e3a8a",
            Info = "#2563eb",
            Success = "#10b981",
            Warning = "#f59e0b",
            Error = "#ef4444",
            Divider = "rgba(0,0,0,0.06)",
            TableLines = "rgba(0,0,0,0.04)"
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#60a5fa",
            Secondary = "#94a3b8",
            Background = "#0f172a",
            Surface = "#1e293b",
            AppbarBackground = "rgba(15, 23, 42, 0.9)",
            AppbarText = "#f1f5f9",
            DrawerBackground = "#020617",
            TextPrimary = "#f1f5f9",
            TextSecondary = "#94a3b8",
            ActionDefault = "#60a5fa",
            Divider = "rgba(255,255,255, 0.12)"
        },
        LayoutProperties = new LayoutProperties()
        {
            DefaultBorderRadius = "16px",
            AppbarHeight = "76px"
        }
    };
}
