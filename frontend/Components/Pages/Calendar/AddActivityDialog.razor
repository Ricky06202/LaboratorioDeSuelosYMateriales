@using frontend.Models
@using MudBlazor
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Event" Class="mr-2" />
            @(IsEditMode ? "Editar Actividad" : "Nueva Actividad")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="@_success">
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.Title" Label="Título" Variant="Variant.Outlined" Required="true" RequiredError="El título es requerido" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.Description" Label="Descripción" Variant="Variant.Outlined" Lines="3" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudDatePicker Label="Fecha" Variant="Variant.Outlined" Required="true" RequiredError="La fecha es requerida" 
                                Date="_model.StartDate" DateChanged="OnStartDateChanged" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTimePicker Label="Hora" Variant="Variant.Outlined" 
                                Value="_selectedTime" ValueChanged="OnTimeChanged" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect @bind-Value="_model.Type" Label="Tipo" Variant="Variant.Outlined">
                        <MudSelectItem Value="@(string.Empty)">Seleccionar tipo</MudSelectItem>
                        <MudSelectItem Value="@("Prueba de Campo")">Prueba de Campo</MudSelectItem>
                        <MudSelectItem Value="@("Muestreo")">Muestreo</MudSelectItem>
                        <MudSelectItem Value="@("Reunión")">Reunión</MudSelectItem>
                        <MudSelectItem Value="@("Visita")">Visita</MudSelectItem>
                        <MudSelectItem Value="@("Otro")">Otro</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Color</MudText>
                    <div class="d-flex gap-2 flex-wrap">
                        @foreach (var color in _availableColors)
                        {
                            <div class="color-option @(color == _model.Color ? "selected" : "")" 
                                 style="background-color: @color;"
                                 @onclick="() => _model.Color = color">
                            </div>
                        }
                    </div>
                    <MudTextField @bind-Value="_model.Color" Label="Color personalizado (hex)" Variant="Variant.Outlined" Class="mt-2" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@(!_success)" Class="rounded-pill px-6">
            @(IsEditMode ? "Actualizar" : "Guardar")
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    .color-option {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        cursor: pointer;
        border: 2px solid transparent;
        transition: all 0.2s;
    }
    
    .color-option:hover {
        transform: scale(1.1);
    }
    
    .color-option.selected {
        border-color: white;
        box-shadow: 0 0 0 2px var(--mud-palette-primary);
    }
</style>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public DateTime InitialDate { get; set; } = DateTime.Today;
    [Parameter] public CalendarActivity? ExistingActivity { get; set; }
    [Parameter] public bool IsEditMode { get; set; }

    private CalendarActivityCreate _model = new();
    private MudForm _form = null!;
    private bool _success;
    private TimeSpan? _selectedTime;

    private readonly string[] _availableColors = new[]
    {
        "#594AE2", // Morado principal
        "#2196F3", // Azul
        "#4CAF50", // Verde
        "#FF9800", // Naranja
        "#F44336", // Rojo
        "#9C27B0", // Violeta
        "#00BCD4", // Cian
        "#FFEB3B", // Amarillo
        "#795548", // Marrón
        "#607D8B"  // Gris
    };

    protected override void OnInitialized()
    {
        if (IsEditMode && ExistingActivity != null)
        {
            _model.Title = ExistingActivity.Title;
            _model.Description = ExistingActivity.Description;
            _model.StartDate = ExistingActivity.StartDate;
            _model.Type = ExistingActivity.Type;
            _model.Color = ExistingActivity.Color;
            _selectedTime = ExistingActivity.StartDate.TimeOfDay;
        }
        else
        {
            _model.StartDate = InitialDate;
            _selectedTime = InitialDate.TimeOfDay;
            _model.Color = _availableColors[0];
        }
    }

    private void OnStartDateChanged(DateTime? date)
    {
        if (date.HasValue)
        {
            _model.StartDate = date.Value;
        }
    }

    private void OnTimeChanged(TimeSpan? time)
    {
        _selectedTime = time;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void Submit()
    {
        if (_selectedTime.HasValue)
        {
            _model.StartDate = _model.StartDate.Date + _selectedTime.Value;
        }

        MudDialog.Close(DialogResult.Ok(_model));
    }
}
