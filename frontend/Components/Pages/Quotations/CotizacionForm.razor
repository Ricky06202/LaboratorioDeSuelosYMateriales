@using frontend.Models
@using frontend.Services
@using MudBlazor
@inject CustomerService CustomerService
@inject QuotationService QuotationService
@inject LabServiceService LabServiceService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="@_success">
            <MudGrid>
                <!-- Cliente Section -->
                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-2">Información del Cliente</MudText>
                </MudItem>
                
                @if (_isFromOrder || _selectedCustomer != null)
                {
                    <MudItem xs="12">
                        <MudPaper Class="pa-4 rounded-lg" Style="background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%); color: white;">
                            <MudGrid>
                                <MudItem xs="12">
                                    <div class="d-flex align-center">
                                        <MudAvatar Style="background-color: rgba(255,255,255,0.2); color: white;" Size="Size.Large" Class="mr-3">
                                            <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Large" />
                                        </MudAvatar>
                                        <div>
                                            <MudText Typo="Typo.h6" Class="font-weight-bold" Style="color: white;">
                                                @_quotation.ClientName
                                            </MudText>
                                            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.8);">
                                                Cliente registrado
                                            </MudText>
                                        </div>
                                    </div>
                                </MudItem>
                                <MudItem xs="12"><MudDivider Class="my-2" Style="background-color: rgba(255,255,255,0.2);" /></MudItem>
                                <MudItem xs="12" sm="6">
                                    <div class="d-flex align-center">
                                        <MudIcon Icon="@Icons.Material.Filled.Badge" Size="Size.Small" Class="mr-2" Style="color: rgba(255,255,255,0.8);" />
                                        <div>
                                            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.7);">RUC</MudText>
                                            <MudText Typo="Typo.body1" Class="font-weight-medium" Style="color: white;">@_quotation.ClientRuc</MudText>
                                        </div>
                                    </div>
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <div class="d-flex align-center">
                                        <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" Class="mr-2" Style="color: rgba(255,255,255,0.8);" />
                                        <div>
                                            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.7);">Teléfono</MudText>
                                            <MudText Typo="Typo.body1" Class="font-weight-medium" Style="color: white;">@_quotation.ClientPhone</MudText>
                                        </div>
                                    </div>
                                </MudItem>
                                @if (!string.IsNullOrEmpty(_quotation.ClientDirection))
                                {
                                    <MudItem xs="12" sm="6">
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Class="mr-2" Style="color: rgba(255,255,255,0.8);" />
                                            <div>
                                                <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.7);">Dirección</MudText>
                                                <MudText Typo="Typo.body2" Style="color: white;">@_quotation.ClientDirection</MudText>
                                            </div>
                                        </div>
                                    </MudItem>
                                }
                                @if (!string.IsNullOrEmpty(_quotation.ClientEmail))
                                {
                                    <MudItem xs="12" sm="6">
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Small" Class="mr-2" Style="color: rgba(255,255,255,0.8);" />
                                            <div>
                                                <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.7);">Correo</MudText>
                                                <MudText Typo="Typo.body2" Style="color: white;">@_quotation.ClientEmail</MudText>
                                            </div>
                                        </div>
                                    </MudItem>
                                }
                            </MudGrid>
                        </MudPaper>
                    </MudItem>
                }
                else
                {
                    <MudItem xs="12">
                        <CustomerSelector Label="Seleccionar Cliente" Value="_selectedCustomer" ValueChanged="OnCustomerChanged" Required="true" />
                    </MudItem>
                }
                
                @if (_selectedCustomer != null && !_isFromOrder)
                {
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_quotation.ClientRuc" Label="RUC" Margin="Margin.Dense" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_quotation.ClientPhone" Label="Teléfono" Margin="Margin.Dense" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_quotation.ClientDirection" Label="Dirección" Lines="2" Margin="Margin.Dense" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_quotation.ClientEmail" Label="Correo Electrónico" Margin="Margin.Dense" Variant="Variant.Outlined" />
                    </MudItem>
                }

                <!-- Project Section -->
                <MudItem xs="12"><MudDivider Class="my-4" /></MudItem>
                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-2">Información del Proyecto</MudText>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_quotation.ProjectName" Label="Nombre del Proyecto" Margin="Margin.Dense" Variant="Variant.Outlined" Required="true" RequiredError="El nombre del proyecto es requerido" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_quotation.ProjectLocation" Label="Ubicación" Margin="Margin.Dense" Variant="Variant.Outlined" />
                </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_quotation.ProjectResponsable" Label="Responsable" Margin="Margin.Dense" Variant="Variant.Outlined" />
                        </MudItem>

                <!-- Items Section -->
                <MudItem xs="12"><MudDivider Class="my-4" /></MudItem>
                <MudItem xs="12">
                    <div class="d-flex justify-space-between align-center mb-2">
                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Items de la Cotización</MudText>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="AddItem">Agregar Item</MudButton>
                    </div>
                </MudItem>
                <MudItem xs="12">
                    @foreach (var item in _quotation.Items)
                    {
                        <MudPaper Class="pa-4 mb-2 rounded-lg lsmch-glass-inset">
                            <MudGrid>
                                <MudItem xs="12" sm="4">
                                    <MudAutocomplete T="LabService" Label="Seleccionar Ensayo del Catálogo" 
                                                    Value="item.SelectedService" 
                                                    SearchFunc="@(SearchServices)"
                                                    ToStringFunc="@(s => s == null ? "" : $"{s.Code} - {s.Name}")"
                                                    ResetValueOnEmptyText="true"
                                                    Margin="Margin.Dense" Variant="Variant.Outlined" 
                                                    ValueChanged="@(service => OnServiceSelected(item, service))" />
                                </MudItem>
                                <MudItem xs="12" sm="8">
                                    <MudTextField @bind-Value="item.Description" Label="Descripción del Ensayo" Margin="Margin.Dense" Variant="Variant.Outlined" ReadOnly="@(item.SelectedService != null)" />
                                </MudItem>
                                <MudItem xs="12" sm="3">
                                    <MudSelect @bind-Value="item.ItemSample" Label="Tipo de Muestra" Margin="Margin.Dense" Variant="Variant.Outlined">
                                        <MudSelectItem Value="@("Concreto")">Concreto</MudSelectItem>
                                        <MudSelectItem Value="@("Suelo")">Suelo</MudSelectItem>
                                        <MudSelectItem Value="@("Inspección")">Inspección</MudSelectItem>
                                        <MudSelectItem Value="@("Agregado")">Agregado</MudSelectItem>
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" sm="3">
                                    <MudTextField @bind-Value="item.ItemNorma" Label="Norma / Método" Margin="Margin.Dense" Variant="Variant.Outlined" ReadOnly="@(item.SelectedService != null)" />
                                </MudItem>
                                <MudItem xs="12" sm="3">
                                    <MudNumericField @bind-Value="item.Amount" Label="Cantidad" Margin="Margin.Dense" Min="1" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" sm="3">
                                    <MudNumericField @bind-Value="item.UnitPrice" Label="Precio Unitario (B/.)" Margin="Margin.Dense" Format="F2" Step="0.1M" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AttachMoney" Variant="Variant.Outlined" ReadOnly="@(item.SelectedService != null)" />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudTextField @bind-Value="item.ItemNote" Label="Nota / Observación del Ítem" Margin="Margin.Dense" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" sm="4" Class="d-flex align-center">
                                    <MudText Typo="Typo.subtitle2" Class="font-weight-bold color-primary">Total: B/. @((item.Amount * item.UnitPrice).ToString("N2"))</MudText>
                                </MudItem>
                                <MudItem xs="12" sm="8" Class="d-flex justify-end gap-2">
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => RemoveItem(item))" title="Eliminar" />
                                </MudItem>
                            </MudGrid>
                        </MudPaper>
                    }
                </MudItem>

                <!-- Costs Section -->
                <MudItem xs="12"><MudDivider Class="my-4" /></MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField @bind-Value="_quotation.MobilizationCost" Label="Costo de Movilización (B/.)" Margin="Margin.Dense" Format="F2" Step="0.1M" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField @bind-Value="_quotation.ViaticsCost" Label="Viáticos (B/.)" Margin="Margin.Dense" Format="F2" Step="0.1M" Variant="Variant.Outlined" />
                </MudItem>

                <!-- Totals -->
                <MudItem xs="12"><MudDivider Class="my-4" /></MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_quotation.Note" Label="Notas / Observaciones" Lines="3" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6" Class="d-flex align-center justify-end">
                    <div class="text-right">
                        <MudText Typo="Typo.h6" Color="Color.Primary">Total Cotización: B/. @GrandTotal.ToString("N2")</MudText>
                    </div>
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@(!_success || _processing)" Class="rounded-pill px-6">
            @if (_processing)
            {
                <MudProgressCircular Class="mr-2" Size="Size.Small" Indeterminate="true" />
                <span>Guardando...</span>
            }
            else
            {
                <span>Guardar Cotización</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    .color-primary { color: var(--mud-palette-primary); }
</style>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public QuotationCreate? InitialData { get; set; }
    [Parameter] public Guid? CustomerId { get; set; }

    private QuotationCreate _quotation = new() { Items = new() };
    private Customer? _selectedCustomer;
    private MudForm _form = null!;
    private bool _success;
    private bool _processing;
    private bool _isFromOrder;
    private List<LabService> _allServices = new();

    protected override async Task OnInitializedAsync()
    {
        _allServices = await LabServiceService.GetServicesAsync();
        
        if (InitialData != null)
        {
            _quotation = InitialData;
            _isFromOrder = _quotation.CustomerOrderId.HasValue;
            if (_quotation.CustomerId.HasValue && _quotation.CustomerId != Guid.Empty)
            {
                await LoadCustomerAsync(_quotation.CustomerId.Value);
            }
        }
    }

    private async Task<IEnumerable<LabService>> SearchServices(string value, CancellationToken token)
    {
        if (string.IsNullOrEmpty(value))
            return _allServices;
        
        await Task.Delay(5, token);
        return _allServices.Where(s => 
            s.Name.Contains(value, StringComparison.OrdinalIgnoreCase) ||
            s.Code.Contains(value, StringComparison.OrdinalIgnoreCase) ||
            (s.Norm?.Contains(value, StringComparison.OrdinalIgnoreCase) ?? false)
        );
    }

    private void OnServiceSelected(QuotationItemCreate item, LabService? service)
    {
        item.SelectedService = service;
        if (service != null)
        {
            item.Description = service.Name;
            item.ItemNorma = service.Norm;
            item.UnitPrice = service.UnitPrice;
        }
    }

    private async Task LoadCustomerAsync(Guid customerId)
    {
        try
        {
            var customer = await CustomerService.GetCustomerAsync(customerId);
            if (customer != null)
            {
                _selectedCustomer = customer;
                OnCustomerChanged(customer);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading customer: {ex.Message}");
        }
    }

    private void OnCustomerChanged(Customer? customer)
    {
        _selectedCustomer = customer;
        if (customer != null)
        {
            _quotation.CustomerId = customer.Id;
            _quotation.ClientName = customer.Name;
            _quotation.ClientRuc = customer.Ruc;
            _quotation.ClientDirection = customer.Address;
            _quotation.ClientPhone = customer.Phone;
            _quotation.ClientEmail = customer.Email;
        }
        else
        {
            _quotation.CustomerId = null;
            _quotation.ClientName = string.Empty;
            _quotation.ClientRuc = string.Empty;
            _quotation.ClientDirection = string.Empty;
            _quotation.ClientPhone = string.Empty;
            _quotation.ClientEmail = string.Empty;
        }
    }

    private decimal SubtotalItems => _quotation.Items.Sum(x => x.Amount * x.UnitPrice);
    private decimal GrandTotal => SubtotalItems + _quotation.MobilizationCost + _quotation.ViaticsCost;

    private void AddItem()
    {
        _quotation.Items.Add(new QuotationItemCreate());
    }

    private void RemoveItem(QuotationItemCreate item)
    {
        _quotation.Items.Remove(item);
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task Submit()
    {
        await _form.Validate();
        if (_success)
        {
            _processing = true;
            try
            {
                var createdQuotation = await QuotationService.CreateQuotationAsync(_quotation);
                Snackbar.Add("Cotización creada exitosamente", Severity.Success);
                MudDialog.Close(DialogResult.Ok(createdQuotation));
            }
            catch (Exception ex)
            {
                Snackbar.Add(ex.Message, Severity.Error);
            }
            finally
            {
                _processing = false;
            }
        }
    }
}
