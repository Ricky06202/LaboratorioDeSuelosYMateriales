@using frontend.Models
@using frontend.Services
@using MudBlazor
@inject QuotationService QuotationService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="@_success">
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_quotation.ClientName" Label="Nombre del Cliente" Required="true" RequiredError="Cliente es requerido" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_quotation.ClientRuc" Label="RUC Cliente" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_quotation.ClientDirection" Label="Dirección Cliente" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_quotation.ClientPhone" Label="Teléfono Cliente" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_quotation.ClientEmail" Label="Correo Electrónico" />
                </MudItem>
                
                <MudItem xs="12">
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.subtitle2">Datos del Proyecto</MudText>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_quotation.ProjectName" Label="Nombre del Proyecto" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_quotation.ProjectLocation" Label="Ubicación" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_quotation.ProjectResponsable" Label="Responsable (Encargado)" />
                </MudItem>

                <MudItem xs="12">
                    <MudDivider Class="my-2" />
                    <div class="d-flex justify-content-between align-center mb-2">
                        <MudText Typo="Typo.subtitle2">Ítems de Ensayo o Inspección</MudText>
                        <MudButton Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="AddItem">Agregar Ítem</MudButton>
                    </div>
                    
                    @if (_quotation.Items.Count == 0)
                    {
                        <MudAlert Severity="Severity.Info">No hay ítems agregados.</MudAlert>
                    }
                    else
                    {
                        @foreach (var item in _quotation.Items.Select((v, i) => new { Value = v, Index = i }))
                        {
                            <MudPaper Outlined="true" Class="p-3 mb-2" Elevation="0">
                                <MudGrid>
                                    <MudItem xs="12" sm="3">
                                        <MudTextField @bind-Value="item.Value.ItemNorma" Label="Norma / Método" Margin="Margin.Dense" />
                                    </MudItem>
                                    <MudItem xs="12" sm="3">
                                        <MudTextField @bind-Value="item.Value.ItemSample" Label="Muestra / Ítem" Margin="Margin.Dense" />
                                    </MudItem>
                                    <MudItem xs="12" sm="6">
                                        <MudTextField @bind-Value="item.Value.Description" Label="Descripción del Ensayo" Margin="Margin.Dense" />
                                    </MudItem>
                                    
                                    <MudItem xs="12" sm="3">
                                        <MudNumericField @bind-Value="item.Value.Amount" Label="Cantidad" Margin="Margin.Dense" Min="1" />
                                    </MudItem>
                                    <MudItem xs="12" sm="4">
                                        <MudNumericField @bind-Value="item.Value.UnitPrice" Label="Precio Unitario (B/.)" Margin="Margin.Dense" Format="F2" Step="0.1M" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AttachMoney" />
                                    </MudItem>
                                    <MudItem xs="12" sm="4" Class="d-flex align-center">
                                        <MudText Typo="Typo.body2">Total: B/. @((item.Value.Amount * item.Value.UnitPrice).ToString("F2"))</MudText>
                                    </MudItem>
                                    <MudItem xs="12" sm="1" Class="d-flex justify-end pr-0">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => RemoveItem(item.Value))" />
                                    </MudItem>
                                </MudGrid>
                            </MudPaper>
                        }
                    }
                </MudItem>

                <MudItem xs="12">
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.subtitle2">Servicios Adicionales</MudText>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudNumericField @bind-Value="_quotation.MobilizationCost" Label="Costo Movilización (B/.)" Format="F2" Step="0.1M" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Commute" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField @bind-Value="_quotation.ViaticsCost" Label="Viáticos del Personal (B/.)" Format="F2" Step="0.1M" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.LocalDining" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_quotation.Note" Label="Notas / Observaciones" Lines="2" />
                </MudItem>

                <MudItem xs="12">
                    <MudPaper Class="pa-4 mt-2" Elevation="1" Style="background-color: var(--mud-palette-background-grey);">
                        <div class="d-flex justify-space-between align-center mb-1">
                            <MudText>Subtotal Ítems:</MudText>
                            <MudText>B/. @SubtotalItems.ToString("F2")</MudText>
                        </div>
                        <div class="d-flex justify-space-between align-center mb-1">
                            <MudText>Movilización + Viáticos:</MudText>
                            <MudText>B/. @((_quotation.MobilizationCost + _quotation.ViaticsCost).ToString("F2"))</MudText>
                        </div>
                        <MudDivider Class="my-2" />
                        <div class="d-flex justify-space-between align-center">
                            <MudText Typo="Typo.h6">Total General:</MudText>
                            <MudText Typo="Typo.h6" Color="Color.Primary">B/. @GrandTotal.ToString("F2")</MudText>
                        </div>
                    </MudPaper>
                </MudItem>

            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@_processing">Guardar Cotización</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    private QuotationCreate _quotation = new() { Items = new() };
    private MudForm _form = null!;
    private bool _success;
    private bool _processing;

    private decimal SubtotalItems => _quotation.Items.Sum(x => x.Amount * x.UnitPrice);
    private decimal GrandTotal => SubtotalItems + _quotation.MobilizationCost + _quotation.ViaticsCost;

    private void AddItem()
    {
        _quotation.Items.Add(new QuotationItemCreate());
    }

    private void RemoveItem(QuotationItemCreate item)
    {
        _quotation.Items.Remove(item);
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task Submit()
    {
        await _form.Validate();
        if (_success)
        {
            _processing = true;
            try
            {
                await QuotationService.CreateQuotationAsync(_quotation);
                Snackbar.Add("Cotización creada exitosamente", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            catch (Exception ex)
            {
                Snackbar.Add(ex.Message, Severity.Error);
            }
            finally
            {
                _processing = false;
            }
        }
    }
}
