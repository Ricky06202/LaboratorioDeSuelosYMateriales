@page "/cotizaciones"
@using frontend.Models
@using frontend.Services
@using frontend.Components.Pages.ServiceOrders
@using Microsoft.JSInterop
@inject QuotationService QuotationService
@inject ServiceOrderService ServiceOrderService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>Cotizaciones - LSMCH</PageTitle>

<div class="animate__animated animate__fadeIn">
    <div class="section-header d-flex align-center justify-space-between mb-8">
        <div>
            <MudText Typo="Typo.h4" Class="font-weight-black lsmch-title">COTIZACIONES</MudText>
            <MudText Typo="Typo.subtitle1" Class="text-secondary">Gestión de presupuestos y propuestas comerciales</MudText>
        </div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" 
                   OnClick="OpenNewQuotationDialog" Class="rounded-pill px-8 shadow-lg">Nueva Cotización</MudButton>
    </div>

<MudTable Items="@_quotations" Hover="true" Loading="@_loading" LoadingProgressColor="Color.Info" Filter="new Func<Quotation,bool>(FilterFunc1)">
    <ToolBarContent>
        <MudSpacer />
        <MudTextField @bind-Value="_searchString" Placeholder="Buscar cotización..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>Nº Cotización</MudTh>
        <MudTh>Fecha</MudTh>
        <MudTh>Cliente</MudTh>
        <MudTh>Proyecto</MudTh>
        <MudTh>Total</MudTh>
        <MudTh>Acciones</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Nº Cotización">@context.QuotationNumber</MudTd>
        <MudTd DataLabel="Fecha">@context.Date.ToShortDateString()</MudTd>
        <MudTd DataLabel="Cliente">@context.ClientName</MudTd>
        <MudTd DataLabel="Proyecto">@context.ProjectName</MudTd>
        <MudTd DataLabel="Total">B/. @context.TotalAmount.ToString("F2")</MudTd>
        <MudTd DataLabel="Acciones">
            <MudIconButton Icon="@Icons.Material.Filled.PictureAsPdf" Color="Color.Error" Size="Size.Small" OnClick="@(() => DownloadPdf(context.Id, context.QuotationNumber))" title="Descargar PDF" />
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="@(() => OpenEditQuotationDialog(context))" title="Editar" />
            <MudIconButton Icon="@Icons.Material.Filled.AssignmentTurnedIn" Color="Color.Success" Size="Size.Small" OnClick="@(() => GenerateServiceOrder(context))" title="Generar Orden de Servicio" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Default" Size="Size.Small" OnClick="@(() => DeleteQuotation(context))" title="Eliminar" />
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>
</div>

@code {
    private List<Quotation> _quotations = new();
    private bool _loading = true;
    private string _searchString = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        try
        {
            _quotations = await QuotationService.GetQuotationsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar cotizaciones: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private bool FilterFunc1(Quotation element) => FilterFunc(element, _searchString);

    private bool FilterFunc(Quotation element, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (element.ClientName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.QuotationNumber.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if ($"{element.ProjectName}".Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    }

    private async Task OpenNewQuotationDialog()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<CotizacionForm>("Crear Cotización", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await LoadDataAsync();
        }
    }

    private async Task DeleteQuotation(Quotation quotation)
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Eliminar Cotización",
            $"¿Está seguro de eliminar la cotización {quotation.QuotationNumber}?",
            yesText: "Eliminar", cancelText: "Cancelar");

        if (result == true)
        {
            try
            {
                await QuotationService.DeleteQuotationAsync(quotation.Id);
                Snackbar.Add("Cotización eliminada", Severity.Success);
                await LoadDataAsync();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task DownloadPdf(Guid id, string quotationNumber)
    {
        try
        {
            var pdfBytes = await QuotationService.GetQuotationPdfAsync(id);
            var base64 = Convert.ToBase64String(pdfBytes);
            await JS.InvokeVoidAsync("downloadFileFromStream", $"Cotizacion_{quotationNumber}.pdf", "application/pdf", base64);
            Snackbar.Add("PDF generado con éxito", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error generando PDF: {ex.Message}", Severity.Error);
        }
    }

    private async Task GenerateServiceOrder(Quotation quotation)
    {
        // Verificar si ya existe una orden de servicio para esta cotización
        try
        {
            // Aquí deberías verificar si ya existe una orden de servicio
            // Por ahora, mostramos un mensaje de confirmación
            var dialogResult = await DialogService.ShowMessageBoxAsync(
                "Generar Orden de Servicio",
                $"¿Desea generar una orden de servicio para la cotización {quotation.QuotationNumber}?",
                yesText: "Sí, generar", cancelText: "Cancelar");
            
            if (dialogResult != true)
            {
                return;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error verificando órdenes existentes: {ex.Message}");
        }

        var parameters = new DialogParameters<OrdenServicioForm>
        {
            { x => x.InitialData, new ServiceOrderCreate 
                { 
                    CustomerId = quotation.CustomerId,
                    ClientName = quotation.ClientName,
                    ClientRuc = quotation.ClientRuc,
                    ClientDirection = quotation.ClientDirection,
                    ClientPhone = quotation.ClientPhone,
                    ClientEmail = quotation.ClientEmail,
                    ProjectName = quotation.ProjectName,
                    ProjectLocation = quotation.ProjectLocation,
                    QuotationRef = quotation.QuotationNumber,
                    TotalCost = quotation.TotalAmount
                } 
            }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<OrdenServicioForm>("Generar Orden de Servicio", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            Snackbar.Add("Orden de Servicio generada a partir de la cotización", Severity.Success);
        }
    }

    private async Task OpenEditQuotationDialog(Quotation quotation)
    {
        var parameters = new DialogParameters<CotizacionForm>
        {
            { x => x.InitialData, new QuotationCreate 
                { 
                    CustomerId = quotation.CustomerId,
                    ClientName = quotation.ClientName,
                    ClientRuc = quotation.ClientRuc,
                    ClientDirection = quotation.ClientDirection,
                    ClientPhone = quotation.ClientPhone,
                    ClientEmail = quotation.ClientEmail,
                    ProjectName = quotation.ProjectName,
                    ProjectLocation = quotation.ProjectLocation,
                    ProjectResponsable = quotation.ProjectResponsable,
                    MobilizationCost = quotation.MobilizationCost,
                    ViaticsCost = quotation.ViaticsCost,
                    Note = quotation.Note,
                    Items = quotation.Items.Select(i => new QuotationItemCreate
                    {
                        Description = i.Description,
                        ItemNorma = i.ItemNorma,
                        ItemSample = i.ItemSample,
                        Amount = i.Amount,
                        UnitPrice = i.UnitPrice
                    }).ToList()
                } 
            }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<CotizacionForm>("Editar Cotización", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await LoadDataAsync();
        }
    }
}
