@page "/inventario"
@using frontend.Models
@using frontend.Services
@inject EquipmentService EquipmentService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JS

<div class="d-flex align-center mb-6">
    <MudIcon Icon="@Icons.Material.Filled.Inventory" Size="Size.Large" Color="Color.Primary" Class="mr-3" />
    <MudText Typo="Typo.h4" Class="font-weight-bold">Inventario de Equipos</MudText>
</div>

@if (_loadFailed)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-6 rounded-lg shadow-sm">
        No se pudieron cargar los datos del inventario. Por favor, reintente.
    </MudAlert>
}

<MudPaper Elevation="0" Class="pa-6 rounded-xl shadow-sm border">
    <MudTable ServerData="ServerReload" Dense="false" Hover="true" @ref="_table" Elevation="0" Class="rounded-lg overflow-hidden">
        <ToolBarContent>
            @* Remove Add Equipment button as per user request *@
            <MudSpacer />
            <MudSelect T="string" Value="@_selectedEstado" ValueChanged="OnEstadoChanged" Label="Estado" 
                       Variant="Variant.Outlined" Margin="Margin.Dense" Class="mr-4" Style="max-width: 150px;">
                <MudSelectItem Value="@((string?)null)">Todos</MudSelectItem>
                <MudSelectItem Value="@("Activo")">Activos</MudSelectItem>
                <MudSelectItem Value="@("Mantenimiento")">Mantenimiento</MudSelectItem>
                <MudSelectItem Value="@("Danado")">Dañados</MudSelectItem>
                <MudSelectItem Value="@("Baja")">De Baja</MudSelectItem>
            </MudSelect>
            <MudTextField T="string" ValueChanged="@(s=>OnSearch(s))" Placeholder="Buscar por nombre o serie..." 
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" 
                          IconSize="Size.Medium" Class="mt-0" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
        </ToolBarContent>
        <HeaderContent>
            <MudTh>Equipo</MudTh>
            <MudTh>Detalles</MudTh>
            <MudTh>Nº Serie</MudTh>
            <MudTh>Estado</MudTh>
            <MudTh>Acciones</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Equipo">
                <div class="d-flex align-center">
                    <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Medium" Class="mr-3 shadow-sm">
                        @(string.IsNullOrEmpty(context.Nombre) ? "?" : context.Nombre[0])
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.body1" Class="font-weight-bold">@context.Nombre</MudText>
                        <MudText Typo="Typo.caption" Class="opacity-50">ID: @(context.Id.ToString().Length > 8 ? context.Id.ToString().Substring(0, 8) : context.Id.ToString())</MudText>
                    </div>
                </div>
            </MudTd>
            <MudTd DataLabel="Detalles">
                <MudText Typo="Typo.body2">@context.Marca</MudText>
                <MudText Typo="Typo.caption" Class="opacity-75">@context.Modelo</MudText>
            </MudTd>
            <MudTd DataLabel="Nº Serie">
                <code>@context.NumeroSerie</code>
            </MudTd>
            <MudTd DataLabel="Estado">
                <MudChip T="string" Color="@GetColor(context.Estado)" Size="Size.Small" Variant="Variant.Text" Class="font-weight-bold">@context.Estado</MudChip>
            </MudTd>
            <MudTd>
                <div class="d-flex">
                    <MudTooltip Text="Reportes (PDF)">
                        <MudMenu Icon="@Icons.Material.Filled.Description" Size="Size.Small" Color="Color.Secondary" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                            <MudMenuItem OnClick="@(() => OnDownloadReport(context, "purchase_verification"))">Verificación de Compra (LSMCH-8-REV2)</MudMenuItem>
                            <MudMenuItem OnClick="@(() => OnDownloadReport(context, "acquisition"))">Registro de Adquisición (LSMCH-6-REV1)</MudMenuItem>
                            <MudMenuItem OnClick="@(() => OnDownloadReport(context, "maintenance_plan"))">Plan de Mantenimiento (LSMCH-17)</MudMenuItem>
                            
                            @if (context.TipoBien == "Equipo de Medición")
                            {
                                <MudMenuItem OnClick="@(() => OnDownloadReport(context, "measurement"))">Inv. Equipo Medición (LSMCH-9-REV1)</MudMenuItem>
                            }
                            @if (context.TipoBien == "Equipo de Campo o Auxiliar")
                            {
                                <MudMenuItem OnClick="@(() => OnDownloadReport(context, "field_aux"))">Inv. Equipo Campo/Aux (LSMCH-10)</MudMenuItem>
                            }
                            @if (context.TipoBien == "Cristalería")
                            {
                                <MudMenuItem OnClick="@(() => OnDownloadReport(context, "glassware"))">Inv. Cristalería (LSMCH-11)</MudMenuItem>
                            }
                        </MudMenu>
                    </MudTooltip>
                    <MudTooltip Text="Gestionar Calibraciones">
                        <MudIconButton Icon="@Icons.Material.Filled.FactCheck" Size="Size.Small" Color="Color.Info" 
                                       OnClick="@(() => OnManageCalibrations(context))" Class="mr-1" />
                    </MudTooltip>
                    @* Remove Edit button as per user request *@
                    <MudTooltip Text="Eliminar">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" 
                                       OnClick="@(() => OnDeleteEquipment(context))" />
                    </MudTooltip>
                </div>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <div class="pa-8 d-flex flex-column align-center">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Class="mb-3 opacity-25" />
                <MudText Typo="Typo.body1" Class="opacity-50">No se encontraron equipos.</MudText>
            </div>
        </NoRecordsContent>
        <LoadingContent>
            <div class="pa-8 d-flex flex-column align-center">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="mb-3" />
                <MudText Typo="Typo.body1" Class="opacity-50">Cargando inventario...</MudText>
            </div>
        </LoadingContent>
        <PagerContent>
            <MudTablePager InfoFormat="Equipos {from}-{to} de {all}" RowsPerPageString="Filas:" />
        </PagerContent>
    </MudTable>
</MudPaper>

@code {
    private MudTable<Equipo> _table = null!;
    private string _searchString = "";
    private string? _selectedEstado = null;
    private bool _loadFailed = false;

    private async Task<TableData<Equipo>> ServerReload(TableState state, CancellationToken cancellationToken)
    {
        try
        {
            _loadFailed = false;
            var response = await EquipmentService.GetEquiposAsync(state.Page * state.PageSize, state.PageSize, _searchString, _selectedEstado);
            
            if (response == null)
            {
                return new TableData<Equipo>() { TotalItems = 0, Items = Enumerable.Empty<Equipo>() };
            }
            
            return new TableData<Equipo>() { TotalItems = response.Total, Items = response.Items };
        }
        catch (Exception ex)
        {
            _loadFailed = true;
            Snackbar.Add($"Error al cargar inventario: {ex.Message}", Severity.Error);
            return new TableData<Equipo>() { TotalItems = 0, Items = Enumerable.Empty<Equipo>() };
        }
    }

    private void OnSearch(string text)
    {
        _searchString = text;
        if (_table != null) _table.ReloadServerData();
    }
    
    private void OnEstadoChanged(string? estado)
    {
        _selectedEstado = estado;
        if (_table != null) _table.ReloadServerData();
    }

    private async Task OnAddEquipment()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<EquipoDialog>("Nuevo Equipo", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await _table.ReloadServerData();
        }
    }

    private async Task OnEditEquipment(Equipo equipo)
    {
        var parameters = new DialogParameters<EquipoDialog> { { x => x.Equipo, equipo } };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<EquipoDialog>("Editar Equipo", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await _table.ReloadServerData();
        }
    }

    private async Task OnManageCalibrations(Equipo equipo)
    {
        var parameters = new DialogParameters<CalibracionDialog> 
        { 
            { x => x.EquipoId, equipo.Id },
            { x => x.EquipoNombre, equipo.Nombre }
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<CalibracionDialog>("Gestionar Calibraciones", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await _table.ReloadServerData();
        }
    }

    private async Task OnDownloadReport(Equipo equipo, string type)
    {
        try
        {
            Snackbar.Add("Preparando descarga...", Severity.Info);
            
            var pdfStream = await EquipmentService.DownloadEquipmentReportAsync(equipo.Id, type);
            using var memoryStream = new MemoryStream();
            await pdfStream.CopyToAsync(memoryStream);
            var bytes = memoryStream.ToArray();
            var base64 = Convert.ToBase64String(bytes);
            
            var reportCode = type switch
            {
                "purchase_verification" => "LSMCH-8-REV2",
                "acquisition" => "LSMCH-6-REV1",
                "maintenance_plan" => "LSMCH-17",
                "measurement" => "LSMCH-9-REV1",
                "field_aux" => "LSMCH-10",
                "glassware" => "LSMCH-11",
                _ => "REPORTE"
            };
            
            var fileName = $"{reportCode}_{equipo.NumeroSerie}_{DateTime.Now:yyyyMMdd}.pdf";
            await JS.InvokeVoidAsync("downloadFileFromStream", fileName, "application/pdf", base64);
            
            Snackbar.Add($"Reporte {reportCode} descargado con éxito", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al descargar: {ex.Message}", Severity.Error);
        }
    }

    private async Task OnDeleteEquipment(Equipo equipo)
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Eliminar Equipo", 
            $"¿Está seguro que desea eliminar el equipo {equipo.Nombre}?", 
            yesText: "Eliminar", cancelText: "Cancelar");

        if (result == true)
        {
            try
            {
                await EquipmentService.DeleteEquipoAsync(equipo.Id);
                Snackbar.Add("Equipo eliminado", Severity.Success);
                if (_table != null) await _table.ReloadServerData();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error al eliminar: {ex.Message}", Severity.Error);
            }
        }
    }

    private Color GetColor(string estado) => estado switch
    {
        "Activo" => Color.Success,
        "Danado" => Color.Error,
        "Mantenimiento" => Color.Warning,
        _ => Color.Default
    };
}
