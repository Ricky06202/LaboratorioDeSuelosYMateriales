@using frontend.Models
@using frontend.Services
@inject EquipmentService EquipmentService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(IsEdit ? Icons.Material.Filled.Edit : Icons.Material.Filled.Add)" Class="mr-3 mb-n1" />
            @(IsEdit ? "Editar Equipo" : "Nuevo Equipo")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="@_isValid">
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Nombre" Required="true" @bind-Value="_model.Nombre" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Nº Serie" Required="true" @bind-Value="_model.NumeroSerie" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Marca" @bind-Value="_model.Marca" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Modelo" @bind-Value="_model.Modelo" />
                </MudItem>
                <MudItem xs="12">
                    <MudSelect T="string" Label="Estado" @bind-Value="_model.Estado">
                        <MudSelectItem Value="@("Activo")">Activo</MudSelectItem>
                        <MudSelectItem Value="@("Danado")">Dañado</MudSelectItem>
                        <MudSelectItem Value="@("Mantenimiento")">Mantenimiento</MudSelectItem>
                        <MudSelectItem Value="@("Baja")">Baja</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    <div class="d-flex flex-column gap-2">
                        <InputFile id="fileInput" OnChange="UploadFile" hidden accept=".jpg,.png,.jpeg" />
                        <MudButton HtmlTag="label"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.CloudUpload"
                                   for="fileInput">
                            @(string.IsNullOrEmpty(_fotoUrl) ? "Subir Foto" : "Cambiar Foto")
                        </MudButton>
                        @if (!string.IsNullOrEmpty(_fotoUrl))
                        {
                            <MudText Typo="Typo.caption">Foto cargada: @_fotoFileName</MudText>
                        }
                    </div>
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text" Class="mr-2 px-6 rounded-pill">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" Disabled="@(!_isValid || _processing)" 
                   OnClick="Submit" Class="px-8 rounded-pill shadow-sm">
            @if (_processing)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                <MudText Class="ms-2">Guardando...</MudText>
            }
            else
            {
                <MudText>Confirmar</MudText>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudBlazor.IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public Equipo? Equipo { get; set; }

    private bool IsEdit => Equipo != null;
    private MudForm _form = null!;
    private bool _isValid;
    private bool _processing;
    private EquipoCreate _model = new();
    private IBrowserFile? _file;
    private string? _fotoUrl;
    private string? _fotoFileName;

    protected override void OnInitialized()
    {
        if (IsEdit && Equipo != null)
        {
            _model.Nombre = Equipo.Nombre;
            _model.Marca = Equipo.Marca;
            _model.Modelo = Equipo.Modelo;
            _model.NumeroSerie = Equipo.NumeroSerie;
            _model.Estado = Equipo.Estado;
            _model.TipoFondo = Equipo.TipoFondo;
            _model.OrdenCompra = Equipo.OrdenCompra;
            _model.SolicitudNo = Equipo.SolicitudNo;
            _model.TipoBien = Equipo.TipoBien;
            _model.FechaRecibido = Equipo.FechaRecibido;
            _model.IdAsignado = Equipo.IdAsignado;
            _model.Capacidad = Equipo.Capacidad;
            _model.UbicacionFisica = Equipo.UbicacionFisica;
            _model.Proveedor = Equipo.Proveedor;
            _model.EstadoAprobacion = Equipo.EstadoAprobacion;
            _model.Observations = Equipo.Observations;
            _model.VerificadoPor = Equipo.VerificadoPor;
            _model.RevisadoPor = Equipo.RevisadoPor;
            _model.FechaVerificacion = Equipo.FechaVerificacion;
            _model.FechaRevision = Equipo.FechaRevision;
            _model.RangoCalibracion = Equipo.RangoCalibracion;
            _model.FrecuenciaCalibracion = Equipo.FrecuenciaCalibracion;
            _model.MetodoMantenimiento = Equipo.MetodoMantenimiento;
            _model.Criteria1 = Equipo.Criteria1;
            _model.Criteria2 = Equipo.Criteria2;
            _model.Criteria3 = Equipo.Criteria3;
            _model.Criteria4 = Equipo.Criteria4;
            _model.Criteria5 = Equipo.Criteria5;
            _model.Criteria6 = Equipo.Criteria6;
            _model.Criteria7 = Equipo.Criteria7;
            _model.Criteria8 = Equipo.Criteria8;
            _model.Criteria9 = Equipo.Criteria9;
            _model.Criteria10 = Equipo.Criteria10;
            _model.Criteria11 = Equipo.Criteria11;
            _model.Criteria12 = Equipo.Criteria12;
            _model.Criteria13 = Equipo.Criteria13;
            _model.Criteria14 = Equipo.Criteria14;
            _fotoUrl = Equipo.FotoUrl;
        }
    }

    private void UploadFile(InputFileChangeEventArgs e)
    {
        _file = e.File;
        _fotoFileName = e.File.Name;
        _fotoUrl = "temp"; // Just to show something is selected
    }

    private async Task Submit()
    {
        await _form.Validate();
        if (!_isValid) return;

        _processing = true;
        try
        {
            // Upload photo if selected
            Stream? fileStream = null;
            string? fileName = null;
            
            if (_file != null)
            {
                // Max 5MB
                fileStream = _file.OpenReadStream(maxAllowedSize: 1024 * 1024 * 5);
                fileName = _file.Name;
            }

            Equipo result;
            if (IsEdit && Equipo != null)
            {
                var updateModel = new EquipoUpdate
                {
                    Nombre = _model.Nombre,
                    Marca = _model.Marca,
                    Modelo = _model.Modelo,
                    NumeroSerie = _model.NumeroSerie,
                    Estado = _model.Estado,
                    TipoFondo = _model.TipoFondo,
                    OrdenCompra = _model.OrdenCompra,
                    SolicitudNo = _model.SolicitudNo,
                    TipoBien = _model.TipoBien,
                    FechaRecibido = _model.FechaRecibido,
                    IdAsignado = _model.IdAsignado,
                    Capacidad = _model.Capacidad,
                    UbicacionFisica = _model.UbicacionFisica,
                    Proveedor = _model.Proveedor,
                    EstadoAprobacion = _model.EstadoAprobacion,
                    Observations = _model.Observations,
                    VerificadoPor = _model.VerificadoPor,
                    RevisadoPor = _model.RevisadoPor,
                    FechaVerificacion = _model.FechaVerificacion,
                    FechaRevision = _model.FechaRevision,
                    RangoCalibracion = _model.RangoCalibracion,
                    FrecuenciaCalibracion = _model.FrecuenciaCalibracion,
                    MetodoMantenimiento = _model.MetodoMantenimiento,
                    Criteria1 = _model.Criteria1,
                    Criteria2 = _model.Criteria2,
                    Criteria3 = _model.Criteria3,
                    Criteria4 = _model.Criteria4,
                    Criteria5 = _model.Criteria5,
                    Criteria6 = _model.Criteria6,
                    Criteria7 = _model.Criteria7,
                    Criteria8 = _model.Criteria8,
                    Criteria9 = _model.Criteria9,
                    Criteria10 = _model.Criteria10,
                    Criteria11 = _model.Criteria11,
                    Criteria12 = _model.Criteria12,
                    Criteria13 = _model.Criteria13,
                    Criteria14 = _model.Criteria14
                };
                result = await EquipmentService.UpdateEquipoAsync(Equipo.Id, updateModel);
                Snackbar.Add("Equipo actualizado con éxito", Severity.Success);
                
                // If editing and we selected a new file, we do the legacy UploadPhotoAsync
                if (fileStream != null)
                {
                    try
                    {
                        await EquipmentService.UploadPhotoAsync(result.Id, fileStream, fileName!);
                    }
                    catch (Exception ex)
                    {
                        Snackbar.Add($"Equipo actualizado, pero falló la subida de foto: {ex.Message}", Severity.Warning);
                    }
                }
            }
            else
            {
                result = await EquipmentService.CreateEquipoAsync(_model, fileStream, fileName);
                Snackbar.Add("Equipo creado con éxito", Severity.Success);
            }

            MudDialog.Close(DialogResult.Ok(result));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
