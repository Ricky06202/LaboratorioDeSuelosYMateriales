@using frontend.Models
@using frontend.Services
@inject EquipmentService EquipmentService
@inject ISnackbar Snackbar

<MudDialog DisableSidePadding="true">
    <TitleContent>
        <div class="d-flex align-center px-4 pt-2">
            <MudIcon Icon="@Icons.Material.Filled.PrecisionManufacturing" Color="Color.Primary" Class="mr-3" />
            <MudText Typo="Typo.h6">Registro de Nuevo Equipo - Flujo Oficial</MudText>
        </div>
        <div class="px-4 pb-2">
            <MudProgressLinear Color="Color.Primary" Value="@(_step * 25)" Class="my-2" />
            <MudText Typo="Typo.caption" Class="text-secondary">Paso @_step de 4: @StepTitle</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <div style="max-height: 60vh; overflow-y: auto;" class="pa-4">
            @if (_step == 1)
            {
                <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-4">LSMCH 8 Revisión 2: Verificación de Compra</MudText>
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudTextField Label="Orden de Compra No." @bind-Value="_model.PurchaseOrderNo" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Label="Solicitud No." @bind-Value="_model.RequestNo" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="string" Label="Tipo de Bien" @bind-Value="_model.ItemType" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem Value="@("Equipo de Medición")">Equipo de Medición</MudSelectItem>
                            <MudSelectItem Value="@("Equipo Auxiliar")">Equipo Auxiliar</MudSelectItem>
                            <MudSelectItem Value="@("Equipo de Campo")">Equipo de Campo</MudSelectItem>
                            <MudSelectItem Value="@("Cristalería")">Cristalería</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Label="Nombre del Equipo" @bind-Value="_model.EquipmentName" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Label="Marca" @bind-Value="_model.Brand" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Label="Modelo" @bind-Value="_model.Model" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Label="Nº Serie" @bind-Value="_model.SerialNumber" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Label="Proveedor" @bind-Value="_model.Provider" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudDivider Class="my-4" />
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Verificación de Criterios</MudText>
                        <div class="d-flex flex-wrap gap-4">
                            <MudCheckBox @bind-Value="_model.Criteria1" Label="Párametros técnicos OK" Color="Color.Primary" Dense="true" />
                            <MudCheckBox @bind-Value="_model.Criteria2" Label="Especificaciones OC OK" Color="Color.Primary" Dense="true" />
                            <MudCheckBox @bind-Value="_model.Criteria8" Label="Enciende y opera OK" Color="Color.Primary" Dense="true" />
                            <MudCheckBox @bind-Value="_model.Criteria9" Label="Sin daños físicos" Color="Color.Primary" Dense="true" />
                        </div>
                    </MudItem>
                </MudGrid>
            }
            else if (_step == 2)
            {
                <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-4">LSMCH 6 Revisión 1: Registro de Adquisición</MudText>
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="string" Label="Tipo de Fondo" @bind-Value="_model.FundType" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem Value="@("Autogestión")">Autogestión</MudSelectItem>
                            <MudSelectItem Value="@("Fondo Central")">Fondo Central</MudSelectItem>
                            <MudSelectItem Value="@("Inversiones")">Inversiones</MudSelectItem>
                            <MudSelectItem Value="@("Fundación Tecnológica")">Fundación Tecnológica</MudSelectItem>
                            <MudSelectItem Value="@("No Aplica")">No Aplica</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudDatePicker Label="Fecha de Recibido" @bind-Date="_model.ReceiveDate" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Label="ID Asignado (Inventario)" @bind-Value="_model.AssignedId" Placeholder="LSMCH-..." Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField Label="Observaciones de Adquisición" @bind-Value="_model.Observations" Lines="3" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                </MudGrid>
            }
            else if (_step == 3)
            {
                <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-4">LSMCH 8: Programa de Verificación y Calibración</MudText>
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="int" Label="Frecuencia de Calibración" @bind-Value="_model.CalibrationFrequency" SelectedValuesChanged="OnCalibrationDataChanged" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem Value="6">6 Meses</MudSelectItem>
                            <MudSelectItem Value="12">12 Meses (1 Año)</MudSelectItem>
                            <MudSelectItem Value="24">24 Meses (2 Años)</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Label="Rango de Calibración" @bind-Value="_model.CalibrationRange" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudDatePicker Label="Última Calibración" Date="_model.LastCalibrationDate" DateChanged="OnLastCalibrationDateChanged" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Label="Próxima Calibración (Calculada)" Value="@(_model.NextCalibrationDate?.ToString("yyyy-MM-dd") ?? "N/A")" ReadOnly="true" Variant="Variant.Outlined" Margin="Margin.Dense" HelperText="Calculado según frecuencia" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField Label="Calibrado por" @bind-Value="_model.CalibratedBy" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                </MudGrid>
            }
            else if (_step == 4)
            {
                <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-4">@StepTitle</MudText>
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudTextField Label="Ubicación" @bind-Value="_model.Location" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Label="Capacidad" @bind-Value="_model.Capacity" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    @if (_model.ItemType == "Equipo de Medición")
                    {
                        <MudItem xs="12">
                            <MudTextField Label="Método de Mantenimiento" @bind-Value="_model.MaintenanceMethod" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                    }
                    
                    <MudItem xs="12">
                        <MudDivider Class="my-4" />
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Firmas y Aprobación Final</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="string" Label="Estado de Aprobación" @bind-Value="_model.ApprovalStatus" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem Value="@("Aprobado para Uso")">Aprobado para Uso</MudSelectItem>
                            <MudSelectItem Value="@("Rechazado")">Rechazado</MudSelectItem>
                            <MudSelectItem Value="@("Uso Condicionado")">Uso Condicionado</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Label="Verificado por" @bind-Value="_model.VerifiedBy" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Label="Revisado por" @bind-Value="_model.ReviewedBy" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudDatePicker Label="Fecha de Verificación" @bind-Date="_model.VerificationDate" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                </MudGrid>
                
                <div class="mt-8 d-flex flex-column align-center">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Large" Class="mb-2" />
                    <MudText Typo="Typo.body1" Class="text-center">Todos los formularios requeridos han sido completados.</MudText>
                    <MudText Typo="Typo.caption" Class="text-secondary text-center">Al finalizar, se guardará el equipo y se generará el paquete de documentos.</MudText>
                </div>
            }
        </div>
    </DialogContent>
    <DialogActions>
        @if (_step > 1)
        {
            <MudButton OnClick="PrevStep" Variant="Variant.Text" Class="mr-2">Anterior</MudButton>
        }
        <MudSpacer />
        <MudButton Variant="Variant.Text" OnClick="Cancel">Cancelar</MudButton>
        @if (_step < 4)
        {
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="NextStep" Class="rounded-pill px-8">Siguiente</MudButton>
        }
        else
        {
            <MudButton Color="Color.Success" Variant="Variant.Filled" OnClick="Submit" Disabled="@_processing" Class="rounded-pill px-8">
                @if (_processing)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Guardando...</span>
                }
                else
                {
                    <span>Finalizar y Descargar Pack</span>
                }
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    
    private int _step = 1;
    private bool _processing = false;
    private EquipmentWizardModel _model = new();

    private string StepTitle => _step switch
    {
        1 => "LSMCH 8 Rev 2",
        2 => "LSMCH 6 Rev 1",
        3 => "LSMCH 8 Normal",
        4 => _model.ItemType switch
        {
            "Equipo de Medición" => "LSMCH 9 Rev 1",
            "Equipo Auxiliar" => "LSMCH 10",
            "Equipo de Campo" => "LSMCH 10",
            "Cristalería" => "LSMCH 11",
            _ => "Registro Final"
        },
        _ => ""
    };

    private void NextStep() => _step++;
    private void PrevStep() => _step--;
    private void Cancel() => MudDialog.Cancel();

    private void OnLastCalibrationDateChanged(DateTime? date)
    {
        _model.LastCalibrationDate = date;
        CalculateNextCalibration();
    }

    private void OnCalibrationDataChanged()
    {
        CalculateNextCalibration();
    }

    private void CalculateNextCalibration()
    {
        if (_model.LastCalibrationDate.HasValue)
        {
            _model.NextCalibrationDate = _model.LastCalibrationDate.Value.AddMonths(_model.CalibrationFrequency);
        }
    }

    private async Task Submit()
    {
        _processing = true;
        try
        {
                var createModel = new EquipoCreate
                {
                    Nombre = _model.EquipmentName,
                    Marca = _model.Brand,
                    Modelo = _model.Model,
                    NumeroSerie = _model.SerialNumber,
                    Estado = "Activo",
                    TipoFondo = _model.FundType,
                    OrdenCompra = _model.PurchaseOrderNo,
                    SolicitudNo = _model.RequestNo,
                    TipoBien = _model.ItemType,
                    FechaRecibido = _model.ReceiveDate,
                    IdAsignado = _model.AssignedId,
                    Capacidad = _model.Capacity,
                    UbicacionFisica = _model.Location,
                    Proveedor = _model.Provider,
                    EstadoAprobacion = _model.ApprovalStatus,
                    Observations = _model.Observations,
                    VerificadoPor = _model.VerifiedBy,
                    RevisadoPor = _model.ReviewedBy,
                    FechaVerificacion = _model.VerificationDate,
                    FechaRevision = _model.ReviewDate,
                    RangoCalibracion = _model.CalibrationRange,
                    FrecuenciaCalibracion = _model.CalibrationFrequency,
                    MetodoMantenimiento = _model.MaintenanceMethod,
                    Criteria1 = _model.Criteria1,
                    Criteria2 = _model.Criteria2,
                    Criteria3 = _model.Criteria3,
                    Criteria4 = _model.Criteria4,
                    Criteria5 = _model.Criteria5,
                    Criteria6 = _model.Criteria6,
                    Criteria7 = _model.Criteria7,
                    Criteria8 = _model.Criteria8,
                    Criteria9 = _model.Criteria9,
                    Criteria10 = _model.Criteria10,
                    Criteria11 = _model.Criteria11,
                    Criteria12 = _model.Criteria12,
                    Criteria13 = _model.Criteria13,
                    Criteria14 = _model.Criteria14
                };

            var result = await EquipmentService.CreateEquipoAsync(createModel);
            
            // If there's calibration data, create it too
            if (_model.LastCalibrationDate.HasValue && _model.NextCalibrationDate.HasValue)
            {
                var calibModel = new CalibracionCreate
                {
                    EquipoId = result.Id,
                    FechaCalibracion = _model.LastCalibrationDate.Value,
                    FechaVencimiento = _model.NextCalibrationDate.Value,
                    EmpresaCertificadora = _model.CalibratedBy
                };
                await EquipmentService.CreateCalibracionAsync(calibModel);
            }

            Snackbar.Add("Registro completado y equipo creado con éxito", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            var errorMessage = ex.Message;
            if (ex.InnerException != null)
                errorMessage += $" | Internal: {ex.InnerException.Message}";
                
            Snackbar.Add($"Error al crear equipo: {errorMessage}", Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }
}
