@page "/ordenes-servicio"
@using frontend.Models
@using frontend.Services
@using Microsoft.JSInterop
@inject ServiceOrderService ServiceOrderService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>Órdenes de Servicio - LSMCH</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <MudText Typo="Typo.h4">Órdenes de Servicio</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenNewOrderDialog">Nueva Orden</MudButton>
</div>

<MudTable Items="@_orders" Hover="true" Loading="@_loading" LoadingProgressColor="Color.Info" Filter="new Func<ServiceOrder,bool>(FilterFunc1)">
    <ToolBarContent>
        <MudSpacer />
        <MudTextField @bind-Value="_searchString" Placeholder="Buscar orden..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>Nº Orden</MudTh>
        <MudTh>Fecha</MudTh>
        <MudTh>Cliente</MudTh>
        <MudTh>Proyecto</MudTh>
        <MudTh>Total</MudTh>
        <MudTh>Acciones</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Nº Orden">@context.OrderNumber</MudTd>
        <MudTd DataLabel="Fecha">@context.Date.ToShortDateString()</MudTd>
        <MudTd DataLabel="Cliente">@context.ClientName</MudTd>
        <MudTd DataLabel="Proyecto">@context.ProjectName</MudTd>
        <MudTd DataLabel="Total">B/. @context.TotalCost.ToString("F2")</MudTd>
        <MudTd DataLabel="Acciones">
            <MudIconButton Icon="@Icons.Material.Filled.PictureAsPdf" Color="Color.Error" Size="Size.Small" OnClick="@(() => DownloadPdf(context.Id, context.OrderNumber))" title="Descargar PDF" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Default" Size="Size.Small" OnClick="@(() => DeleteOrder(context))" title="Eliminar" />
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>

@code {
    private List<ServiceOrder> _orders = new();
    private bool _loading = true;
    private string _searchString = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        try
        {
            _orders = await ServiceOrderService.GetServiceOrdersAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar órdenes de servicio: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private bool FilterFunc1(ServiceOrder element) => FilterFunc(element, _searchString);

    private bool FilterFunc(ServiceOrder element, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (element.ClientName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.OrderNumber.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if ($"{element.ProjectName}".Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    }

    private async Task OpenNewOrderDialog()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<OrdenServicioForm>("Crear Orden de Servicio", options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadDataAsync();
        }
    }

    private async Task DeleteOrder(ServiceOrder order)
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Eliminar Orden",
            $"¿Está seguro de eliminar la orden {order.OrderNumber}?",
            yesText: "Eliminar", cancelText: "Cancelar");

        if (result == true)
        {
            try
            {
                await ServiceOrderService.DeleteServiceOrderAsync(order.Id);
                Snackbar.Add("Orden eliminada", Severity.Success);
                await LoadDataAsync();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task DownloadPdf(Guid id, string orderNumber)
    {
        try
        {
            var pdfBytes = await ServiceOrderService.GetServiceOrderPdfAsync(id);
            var base64 = Convert.ToBase64String(pdfBytes);
            await JS.InvokeVoidAsync("downloadFileFromStream", $"OrdenServicio_{orderNumber}.pdf", "application/pdf", base64);
            Snackbar.Add("PDF generado con éxito", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error generando PDF: {ex.Message}", Severity.Error);
        }
    }
}
