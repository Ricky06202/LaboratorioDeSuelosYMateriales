@using frontend.Models
@using frontend.Services
@using MudBlazor
@inject ServiceOrderService ServiceOrderService
@inject CustomerService CustomerService
@inject CalendarService CalendarService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="@_success">
            <MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" @bind-ActivePanelIndex="_activeTabIndex">
                <MudTabPanel Text="Datos Generales">
                    <MudGrid>
                        @if (_isFromQuotation || _selectedCustomer != null)
                        {
                            <MudItem xs="12">
                                <MudPaper Class="pa-4 rounded-lg" Style="background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%); color: white;">
                                    <MudGrid>
                                        <MudItem xs="12">
                                            <div class="d-flex align-center">
                                                <MudAvatar Style="background-color: rgba(255,255,255,0.2); color: white;" Size="Size.Large" Class="mr-3">
                                                    <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Large" />
                                                </MudAvatar>
                                                <div>
                                                    <MudText Typo="Typo.h6" Class="font-weight-bold" Style="color: white;">
                                                        @_order.ClientName
                                                    </MudText>
                                                    <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.8);">
                                                        Cliente de Cotización
                                                    </MudText>
                                                </div>
                                            </div>
                                        </MudItem>
                                        <MudItem xs="12"><MudDivider Class="my-2" Style="background-color: rgba(255,255,255,0.2);" /></MudItem>
                                        <MudItem xs="12" sm="4">
                                            <div class="d-flex align-center">
                                                <MudIcon Icon="@Icons.Material.Filled.Badge" Size="Size.Small" Class="mr-2" Style="color: rgba(255,255,255,0.8);" />
                                                <div>
                                                    <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.7);">RUC</MudText>
                                                    <MudText Typo="Typo.body1" Class="font-weight-medium" Style="color: white;">@_order.ClientRuc @if (!string.IsNullOrEmpty(_order.ClientDv)) { <text>-@_order.ClientDv</text> }</MudText>
                                                </div>
                                            </div>
                                        </MudItem>
                                        <MudItem xs="12" sm="4">
                                            <div class="d-flex align-center">
                                                <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" Class="mr-2" Style="color: rgba(255,255,255,0.8);" />
                                                <div>
                                                    <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.7);">Teléfono</MudText>
                                                    <MudText Typo="Typo.body1" Class="font-weight-medium" Style="color: white;">@_order.ClientPhone</MudText>
                                                </div>
                                            </div>
                                        </MudItem>
                                        <MudItem xs="12" sm="4">
                                            <div class="d-flex align-center">
                                                <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" Class="mr-2" Style="color: rgba(255,255,255,0.8);" />
                                                <div>
                                                    <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.7);">Cotización</MudText>
                                                    <MudText Typo="Typo.body2" Style="color: white;">@_order.QuotationRef</MudText>
                                                </div>
                                            </div>
                                        </MudItem>
                                        @if (!string.IsNullOrEmpty(_order.ClientDirection))
                                        {
                                            <MudItem xs="12" sm="6">
                                                <div class="d-flex align-center">
                                                    <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Class="mr-2" Style="color: rgba(255,255,255,0.8);" />
                                                    <div>
                                                        <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.7);">Dirección</MudText>
                                                        <MudText Typo="Typo.body2" Style="color: white;">@_order.ClientDirection</MudText>
                                                    </div>
                                                </div>
                                            </MudItem>
                                        }
                                        @if (!string.IsNullOrEmpty(_order.ClientEmail))
                                        {
                                            <MudItem xs="12" sm="6">
                                                <div class="d-flex align-center">
                                                    <MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Small" Class="mr-2" Style="color: rgba(255,255,255,0.8);" />
                                                    <div>
                                                        <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.7);">Correo</MudText>
                                                        <MudText Typo="Typo.body2" Style="color: white;">@_order.ClientEmail</MudText>
                                                    </div>
                                                </div>
                                            </MudItem>
                                        }
                                    </MudGrid>
                                </MudPaper>
                            </MudItem>
                        }
                        else
                        {
                            <MudItem xs="12" sm="8">
                                <CustomerSelector Label="Nombre del Cliente (Buscador)" Value="_selectedCustomer" ValueChanged="OnCustomerChanged" Required="true" />
                            </MudItem>
                            <MudItem xs="12" sm="4">
                                <MudTextField @bind-Value="_order.ClientRuc" Label="RUC" Margin="Margin.Dense" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" sm="2">
                                <MudTextField @bind-Value="_order.ClientDv" Label="D.V." Margin="Margin.Dense" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="_order.QuotationRef" Label="Cotización aprobada LSMCH No." Margin="Margin.Dense" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" sm="4">
                                <MudTextField @bind-Value="_order.ClientPhone" Label="Teléfono" Margin="Margin.Dense" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" sm="12">
                                <MudTextField @bind-Value="_order.ClientEmail" Label="Correo Electrónico" Margin="Margin.Dense" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField @bind-Value="_order.ClientDirection" Label="Dirección" Lines="2" Margin="Margin.Dense" Variant="Variant.Outlined" />
                            </MudItem>
                        }

                        @if (_selectedCustomer == null || _isFromQuotation)
                        {
                            <MudItem xs="12" sm="@(_isFromQuotation ? 6 : 12)">
                                <MudTextField @bind-Value="_order.QuotationRef" Label="Cotización aprobada LSMCH No." Margin="Margin.Dense" Variant="Variant.Outlined" />
                            </MudItem>
                        }
                        @if (!_isFromQuotation && _selectedCustomer != null)
                        {
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="_order.QuotationRef" Label="Cotización aprobada LSMCH No." Margin="Margin.Dense" Variant="Variant.Outlined" />
                            </MudItem>
                        }

                        <MudItem xs="12"><MudDivider /></MudItem>
                        
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_order.ProjectName" Label="Nombre del Proyecto" Margin="Margin.Dense" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_order.ProjectLocation" Label="Ubicación del Proyecto" Margin="Margin.Dense" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="3">
                            <MudTextField @bind-Value="_order.ProjectLatitude" Label="Latitud" Margin="Margin.Dense" Variant="Variant.Outlined" Placeholder="ej. 8.4328" />
                        </MudItem>
                        <MudItem xs="12" sm="3">
                            <MudTextField @bind-Value="_order.ProjectLongitude" Label="Longitud" Margin="Margin.Dense" Variant="Variant.Outlined" Placeholder="ej. -82.4310" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_order.ProjectResponsable" Label="Responsable (Encargado)" Margin="Margin.Dense" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_order.ProjectPhone" Label="Celular Responsable" Margin="Margin.Dense" Variant="Variant.Outlined" />
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>
                
                <MudTabPanel Text="Servicio y Condiciones">
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudText Typo="Typo.subtitle2">Tipo de Servicio</MudText>
                            <MudCheckBox @bind-Value="_order.ServiceTypeEnsayos" Label="Ensayos" Color="Color.Primary" />
                            <MudCheckBox @bind-Value="_order.ServiceTypeMuestreo" Label="Muestreo" Color="Color.Primary" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudText Typo="Typo.subtitle2">Efectuado por</MudText>
                            <MudCheckBox @bind-Value="_order.PerformedByLaboratory" Label="Laboratorio" Color="Color.Primary" />
                            <MudCheckBox @bind-Value="_order.PerformedByInspection" Label="Inspección" Color="Color.Primary" />
                            <MudCheckBox @bind-Value="_order.PerformedByClient" Label="Cliente" Color="Color.Primary" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudTextField @bind-Value="_order.ItemDescription" Label="Descripción de los ítems de ensayo o inspección, y/o condición del ítem" Lines="3" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_order.Methodology" Label="Metodología: Métodos / Normas / Otros" Lines="2" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>

                        <MudItem xs="12" sm="4">
                            <MudCheckBox @bind-Value="_order.Subcontraction" Label="Subcontratación" Color="Color.Primary" />
                        </MudItem>
                        <MudItem xs="12" sm="8">
                            <MudTextField @bind-Value="_order.SubcontractionDetails" Label="Detalle de Subcontratación" Disabled="@(!_order.Subcontraction)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>

                        <MudItem xs="12" sm="4">
                            <MudCheckBox @bind-Value="_order.RequestDeclarationConformity" Label="Solicita Declaración de Conformidad" Color="Color.Primary" />
                        </MudItem>
                        <MudItem xs="12" sm="8">
                            <MudTextField @bind-Value="_order.DeclarationSpecification" Label="Especificación o Norma" Disabled="@(!_order.RequestDeclarationConformity)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

                <MudTabPanel Text="Reglas y Otros">
                    <MudGrid>
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2">Regla de Decisión</MudText>
                            <MudCheckBox @bind-Value="_order.DecisionRuleNotApplicable" Label="No Aplica" Color="Color.Primary" />
                            <MudCheckBox @bind-Value="_order.DecisionRuleClientAgreed" Label="Acordada con el cliente" Color="Color.Primary" />
                            <MudCheckBox @bind-Value="_order.DecisionRuleInherent" Label="Inherente a especificación/norma" Color="Color.Primary" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2">Desviación Solicitada</MudText>
                            <MudCheckBox @bind-Value="_order.ClientDeviation" Label="Sí" Color="Color.Error" />
                            <MudTextField @bind-Value="_order.DeviationDetails" Label="Detalle si la respuesta es SÍ" Disabled="@(!_order.ClientDeviation)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudTextField @bind-Value="_order.Observations" Label="Observaciones" Lines="3" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudNumericField @bind-Value="_order.SampleConservationTime" Label="Tiempo de conservación de las muestras (días)" Min="0" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        
                        <MudItem xs="12"><MudDivider /></MudItem>

                        <MudItem xs="12" sm="6">
                            <MudNumericField @bind-Value="_order.TotalCost" Label="Costo Total (B/.)" Format="F2" Step="0.1M" Adornment="Adornment.Start" AdornmentText="B/." Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudCheckBox @bind-Value="_order.Paid100Percent" Label="Cancela (100%)" Color="Color.Primary" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_order.ServiceSaleReceiptNumber" Label="Comprobante de venta de Servicios No." Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_order.RelatesToInform" Label="Informe LSMCH No" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudNumericField @bind-Value="_order.NumberOfInforms" Label="Cantidad de Informes" Min="1" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        
                        <MudItem xs="12" sm="6">
                            <MudCheckBox @bind-Value="_order.SupportInstitutional" Label="Apoyo Institucional" Color="Color.Primary" />
                            <MudTextField @bind-Value="_order.RelatedDocument" Label="Documento Relacionado" Disabled="@(!_order.SupportInstitutional)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_order.AttendedBy" Label="Atendido por" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_order.ApplicantName" Label="Solicitante o Emisario" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_order.ApplicantIdNumber" Label="No. de Cédula (Solicitante)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

                <MudTabPanel Text="Agenda">
                    <MudGrid>
                        <MudItem xs="12">
                            <MudAlert Severity="Severity.Info" Class="mb-4">
                                Configure la fecha y hora para agendar automáticamente esta orden de servicio en la agenda del laboratorio.
                            </MudAlert>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudDatePicker Label="Fecha de la Agenda" Variant="Variant.Outlined" Margin="Margin.Dense" 
                                        @bind-PickerDate="_activityDate" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTimePicker Label="Hora de la Agenda" Variant="Variant.Outlined" Margin="Margin.Dense" 
                                        @bind-PickerValue="_activityTime" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Color="Color.Primary">
                                Fecha programada: @GetActivityDateTimeDisplay()
                            </MudText>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>
            </MudTabs>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        @if (_activeTabIndex == 0 || _activeTabIndex == 1)
        {
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="NextTab" Disabled="@_processing" Class="rounded-pill px-6">Siguiente</MudButton>
        }
        @if (_activeTabIndex == 2)
        {
            <MudButton OnClick="PreviousTab">Anterior</MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@_processing" Class="rounded-pill px-6">Guardar Orden</MudButton>
        }
        @if (_activeTabIndex == 3)
        {
            <MudButton OnClick="PreviousTab">Anterior</MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@_processing" Class="rounded-pill px-6">Guardar Orden</MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public ServiceOrderCreate? InitialData { get; set; }
    [Parameter] public DateTime? ActivityDate { get; set; }

    private ServiceOrderCreate _order = new();
    private Customer? _selectedCustomer;
    private MudForm _form = null!;
    private bool _success;
    private bool _processing;
    private int _activeTabIndex = 0;
    private DateTime _activityDate = DateTime.Today.AddDays(1);
    private TimeSpan _activityTime = new TimeSpan(8, 0, 0);
    private bool _isFromQuotation;

    protected override async Task OnInitializedAsync()
    {
        if (InitialData != null)
        {
            _order = InitialData;
            _isFromQuotation = !string.IsNullOrEmpty(_order.QuotationRef);
            if (_order.CustomerId.HasValue && _order.CustomerId != Guid.Empty)
            {
                await LoadCustomerAsync(_order.CustomerId.Value);
            }
        }
    }

    private async Task LoadCustomerAsync(Guid customerId)
    {
        try
        {
            var customer = await CustomerService.GetCustomerAsync(customerId);
            if (customer != null)
            {
                _selectedCustomer = customer;
                OnCustomerChanged(customer);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading customer: {ex.Message}");
        }
    }

    private string GetActivityDateTimeDisplay()
    {
        if (_activityDate != default && _activityTime != TimeSpan.Zero)
        {
            var dateTime = _activityDate.Date + _activityTime;
            return dateTime.ToString("dd/MM/yyyy HH:mm");
        }
        return "No configurada";
    }

    private DateTime? GetActivityDateTime()
    {
        if (_activityDate != default && _activityTime != TimeSpan.Zero)
        {
            return _activityDate.Date + _activityTime;
        }
        return null;
    }

    private void OnActivityDateChanged(DateTime? date)
    {
        if (date.HasValue)
        {
            _activityDate = date.Value;
        }
    }

    private void OnActivityTimeChanged(TimeSpan? time)
    {
        if (time.HasValue)
        {
            _activityTime = time.Value;
        }
    }

    private void OnCustomerChanged(Customer? customer)
    {
        _selectedCustomer = customer;
        if (customer != null)
        {
            _order.CustomerId = customer.Id;
            _order.ClientName = customer.Name;
            _order.ClientRuc = customer.Ruc;
            _order.ClientDv = customer.Dv;
            _order.ClientPhone = customer.Phone;
            _order.ClientEmail = customer.Email;
            _order.ClientDirection = customer.Address;
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void NextTab()
    {
        if (_activeTabIndex < 3)
        {
            _activeTabIndex++;
        }
    }

    private void PreviousTab()
    {
        if (_activeTabIndex > 0)
        {
            _activeTabIndex--;
        }
    }

    private async Task Submit()
    {
        await _form.Validate();
        if (_success)
        {
            _processing = true;
            try
            {
                var createdOrder = await ServiceOrderService.CreateServiceOrderAsync(_order);
                
                try
                {
                    var activityDate = GetActivityDateTime() ?? DateTime.Now.AddDays(1).Date.AddHours(8);

                    await CalendarService.CreateActivityAsync(new CalendarActivityCreate
                    {
                        Title = $"Muestreo/Ensayo: {_order.ClientName}",
                        Description = $"Orden: {createdOrder.OrderNumber} - Proyecto: {_order.ProjectName}",
                        StartDate = activityDate,
                        Type = "Muestreo",
                        RelatedId = createdOrder.Id,
                        Color = "#594AE2"
                    });
                }
                catch (Exception calEx)
                {
                    Console.WriteLine($"Error al sincronizar calendario: {calEx.Message}");
                }

                Snackbar.Add("Orden creada exitosamente y agendada", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            catch (Exception ex)
            {
                Snackbar.Add(ex.Message, Severity.Error);
            }
            finally
            {
                _processing = false;
            }
        }
    }
}
