@page "/peticiones"
@using frontend.Models
@using frontend.Services
@using frontend.Components.Pages.Quotations
@using Microsoft.JSInterop
@inject CustomerOrderService CustomerOrderService
@inject QuotationService QuotationService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>Pedido de Cliente - LSMCH</PageTitle>

<div class="animate__animated animate__fadeIn">
    <div class="section-header d-flex align-center justify-space-between mb-8">
        <div>
            <MudText Typo="Typo.h4" Class="font-weight-black lsmch-title">PEDIDOS DE CLIENTES</MudText>
            <MudText Typo="Typo.subtitle1" Class="text-secondary">Gestión de solicitudes y RA-LSMCH-037</MudText>
        </div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" 
                   OnClick="@(() => OpenOrderDialog())" Class="rounded-pill px-8 shadow-lg">Nuevo Pedido</MudButton>
    </div>

<MudTable Items="@_orders" Hover="true" Loading="@_loading" LoadingProgressColor="Color.Info" Filter="new Func<CustomerOrder,bool>(FilterFunc1)">
    <ToolBarContent>
        <MudSpacer />
        <MudTextField @bind-Value="_searchString" Placeholder="Buscar pedido..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>Nº Pedido</MudTh>
        <MudTh>Fecha</MudTh>
        <MudTh>Cliente</MudTh>
        <MudTh>Proyecto</MudTh>
        <MudTh>Acciones</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Nº Pedido">@context.OrderNumber</MudTd>
        <MudTd DataLabel="Fecha">@context.Date.ToShortDateString()</MudTd>
        <MudTd DataLabel="Cliente">@context.ClientName</MudTd>
        <MudTd DataLabel="Proyecto">@context.ProjectName</MudTd>
        <MudTd DataLabel="Acciones">
             <MudIconButton Icon="@Icons.Material.Filled.PictureAsPdf" Color="Color.Error" Size="Size.Small" OnClick="@(() => DownloadPdf(context.Id, context.OrderNumber))" title="Descargar PDF" />
             <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="@(() => OpenOrderDialog(context))" title="Editar" />
             <MudIconButton Icon="@Icons.Material.Filled.Calculate" Color="Color.Warning" Size="Size.Small" OnClick="@(() => GenerateQuotation(context))" title="Generar Cotización" />
             <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Default" Size="Size.Small" OnClick="@(() => DeleteOrder(context))" title="Eliminar" />
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>
</div>

@code {
    private List<CustomerOrder> _orders = new();
    private bool _loading = true;
    private string _searchString = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        try
        {
            _orders = await CustomerOrderService.GetCustomerOrdersAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar pedidos: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private bool FilterFunc1(CustomerOrder element) => FilterFunc(element, _searchString);

    private bool FilterFunc(CustomerOrder element, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (element.ClientName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.OrderNumber.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if ($"{element.ProjectName}".Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    }

    private async Task OpenOrderDialog(CustomerOrder? order = null)
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        var parameters = new DialogParameters { [nameof(PedidoForm.Order)] = order };
        var dialog = await DialogService.ShowAsync<PedidoForm>(order == null ? "Crear Pedido de Cliente (RA-LSMCH-037)" : "Editar Pedido de Cliente (RA-LSMCH-037)", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await LoadDataAsync();
        }
    }

    private async Task GenerateQuotation(CustomerOrder order)
    {
        // Verificar si ya existe una cotización para este pedido
        try
        {
            var quotations = await QuotationService.GetQuotationsAsync();
            var existingQuotation = quotations.FirstOrDefault(q => 
                q.ProjectName == order.ProjectName && 
                q.ClientName == order.ClientName &&
                q.ProjectLocation == order.ProjectLocation);
            
            if (existingQuotation != null)
            {
                Snackbar.Add($"Ya existe una cotización ({existingQuotation.QuotationNumber}) para este pedido", Severity.Warning);
                return;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error verificando cotizaciones existentes: {ex.Message}");
        }

        var quotationCreate = new QuotationCreate
        {
            CustomerId = order.CustomerId,
            ClientName = order.ClientName,
            ClientRuc = order.ClientRuc,
            ClientDirection = order.ClientDirection,
            ClientPhone = order.ClientPhone,
            ClientEmail = order.ProjectResponsableEmail,
            ProjectName = order.ProjectName,
            ProjectLocation = order.ProjectLocation,
            ProjectResponsable = order.ProjectResponsable,
            Note = $"Generado desde Pedido Nº {order.OrderNumber}. {order.Observations}",
            Items = order.Items.Select(i => new QuotationItemCreate
            {
                Description = i.TestName,
                ItemNorma = i.NormMethod,
                ItemSample = i.SampleType,
                Amount = i.TestCount,
                UnitPrice = 0 
            }).ToList()
        };

        var parameters = new DialogParameters { [nameof(CotizacionForm.InitialData)] = quotationCreate };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<CotizacionForm>("Generar Cotización", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            Snackbar.Add("Cotización generada exitosamente desde el pedido", Severity.Success);
        }
    }

    private async Task DeleteOrder(CustomerOrder order)
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Eliminar Pedido",
            $"¿Está seguro de eliminar el pedido {order.OrderNumber}?",
            yesText: "Eliminar", cancelText: "Cancelar");

        if (result == true)
        {
            try
            {
                await CustomerOrderService.DeleteCustomerOrderAsync(order.Id);
                Snackbar.Add("Pedido eliminado", Severity.Success);
                await LoadDataAsync();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task DownloadPdf(Guid id, string orderNumber)
    {
        try
        {
            var pdfBytes = await CustomerOrderService.GetCustomerOrderPdfAsync(id);
            var base64 = Convert.ToBase64String(pdfBytes);
            await JS.InvokeVoidAsync("downloadFileFromStream", $"Pedido_{orderNumber}.pdf", "application/pdf", base64);
            Snackbar.Add("PDF generado con éxito", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error generando PDF: {ex.Message}", Severity.Error);
        }
    }
}
