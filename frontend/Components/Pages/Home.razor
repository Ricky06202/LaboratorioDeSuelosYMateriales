@page "/"
@using frontend.Models
@using frontend.Services
@inject EquipmentService EquipmentService
@inject ISnackbar Snackbar

<PageTitle>Dashboard - Suelos</PageTitle>

<div class="animate__animated animate__fadeIn">
    <div class="section-header mb-8">
        <MudText Typo="Typo.h4" Class="font-weight-bold lsmch-title">PANEL DE CONTROL GENERAL</MudText>
        <MudText Typo="Typo.subtitle1" Class="text-secondary">Vista técnica del Laboratorio de Suelos y Materiales</MudText>
    </div>

    @if (_loadFailed)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-8 rounded-xl shadow-lg border-0">
            <div class="d-flex align-center justify-space-between">
                <MudText>No se pudo sincronizar con el backend. Por favor, verifique la conexión.</MudText>
                <MudButton Color="Color.Inherit" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh" 
                           Size="Size.Small" OnClick="LoadData" Class="ml-4 rounded-pill">Reintentar Conexión</MudButton>
            </div>
        </MudAlert>
    }

    <MudGrid Class="mb-10">
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="0" Class="stats-card gradient-blue pa-5 rounded-xl">
                <div class="d-flex align-center justify-space-between">
                    <div>
                        <MudText Typo="Typo.subtitle2" Class="opacity-80 text-uppercase font-weight-bold" Style="letter-spacing: 1px;">Total Equipos</MudText>
                        <MudText Typo="Typo.h3" Class="font-weight-black mt-1">@_totalEquipos</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.PrecisionManufacturing" Size="Size.Large" Class="opacity-40" Style="font-size: 3.5rem;" />
                </div>
                <div class="mt-4 pt-3 border-t border-white-10">
                    <MudText Typo="Typo.caption" Class="opacity-60">Inventario actualizado</MudText>
                </div>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="0" Class="stats-card gradient-red pa-5 rounded-xl">
                <div class="d-flex align-center justify-space-between">
                    <div>
                        <MudText Typo="Typo.subtitle2" Class="opacity-80 text-uppercase font-weight-bold" Style="letter-spacing: 1px;">Alertas Críticas</MudText>
                        <MudText Typo="Typo.h3" Class="font-weight-black mt-1">@_criticalAlerts</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.RunningWithErrors" Size="Size.Large" Class="opacity-40" Style="font-size: 3.5rem;" />
                </div>
                <div class="mt-4 pt-3 border-t border-white-10">
                    <MudText Typo="Typo.caption" Class="opacity-60">Requieren calibración inmediata</MudText>
                </div>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="0" Class="stats-card gradient-orange pa-5 rounded-xl">
                <div class="d-flex align-center justify-space-between">
                    <div>
                        <MudText Typo="Typo.subtitle2" Class="opacity-80 text-uppercase font-weight-bold" Style="letter-spacing: 1px;">Próximos Vencimientos</MudText>
                        <MudText Typo="Typo.h3" Class="font-weight-black mt-1">@_upcomingAlerts</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.AccessTimeFilled" Size="Size.Large" Class="opacity-40" Style="font-size: 3.5rem;" />
                </div>
                <div class="mt-4 pt-3 border-t border-white-10">
                    <MudText Typo="Typo.caption" Class="opacity-60">Vencimiento menor a 30 días</MudText>
                </div>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="0" Class="stats-card gradient-green pa-5 rounded-xl">
                <div class="d-flex align-center justify-space-between">
                    <div>
                        <MudText Typo="Typo.subtitle2" Class="opacity-80 text-uppercase font-weight-bold" Style="letter-spacing: 1px;">Estado Óptimo</MudText>
                        <MudText Typo="Typo.h3" Class="font-weight-black mt-1">@(_totalEquipos - _criticalAlerts - _upcomingAlerts)</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.Verified" Size="Size.Large" Class="opacity-40" Style="font-size: 3.5rem;" />
                </div>
                <div class="mt-4 pt-3 border-t border-white-10">
                    <MudText Typo="Typo.caption" Class="opacity-60">Operativos y certificados</MudText>
                </div>
            </MudCard>
        </MudItem>
    </MudGrid>

    <MudPaper Elevation="0" Class="pa-8 rounded-xl shadow-lg border border-solid border-light" Style="background: rgba(255,255,255,0.7); backdrop-filter: blur(8px);">
        <div class="d-flex align-center justify-space-between mb-6">
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.AssignmentLate" Color="Color.Primary" Class="mr-3" />
                <MudText Typo="Typo.h6" Class="font-weight-black">Alertas de Calibración Prioritarias</MudText>
            </div>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward" 
                       href="/inventario" Class="rounded-pill px-6 shadow-sm">Gestionar Inventario</MudButton>
        </div>

    <MudTable Items="@_alerts" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@_loading" 
              Elevation="0" Class="rounded-lg overflow-hidden border">
        <HeaderContent>
            <MudTh>Equipo</MudTh>
            <MudTh>Nº Serie</MudTh>
            <MudTh>Estado</MudTh>
            <MudTh>Vencimiento</MudTh>
            <MudTh>Acción</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Equipo">
                <div class="d-flex align-center">
                    <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Class="mr-3">
                        @(string.IsNullOrEmpty(context.Nombre) ? "?" : context.Nombre[0])
                    </MudAvatar>
                    <MudText Typo="Typo.body2" Class="font-weight-medium">@context.Nombre</MudText>
                </div>
            </MudTd>
            <MudTd DataLabel="Nº Serie">@context.NumeroSerie</MudTd>
            <MudTd DataLabel="Estado">
                <MudChip T="string" Color="@GetColor(context.Estado)" Size="Size.Small" Variant="Variant.Text">@context.Estado</MudChip>
            </MudTd>
            <MudTd DataLabel="Vencimiento">
                @if (context.Calibraciones != null && context.Calibraciones.Any())
                {
                    var lastCal = context.Calibraciones.OrderByDescending(c => c.FechaVencimiento).First();
                    <MudChip T="string" Color="@GetExpirationColor(lastCal.FechaVencimiento)" Size="Size.Small" Label="true">
                        @lastCal.FechaVencimiento.ToShortDateString()
                    </MudChip>
                }
                else
                {
                    <MudText Color="Color.Default" Typo="Typo.caption">Sin datos</MudText>
                }
            </MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.FactCheck" Color="Color.Primary" Size="Size.Small" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            @if (!_loading && !_loadFailed)
            {
                <div class="pa-10 d-flex flex-column align-center">
                    <MudIcon Icon="@Icons.Material.Filled.Verified" Size="Size.Large" Color="Color.Success" Class="mb-3 opacity-25" />
                    <MudText Typo="Typo.h6" Class="opacity-50">¡Todo en regla!</MudText>
                    <MudText Typo="Typo.body2" Class="opacity-25">No hay equipos que requieran atención inmediata.</MudText>
                </div>
            }
        </NoRecordsContent>
    </MudTable>
</MudPaper>
</div>

@code {
    private List<Equipo> _alerts = new();
    private bool _loading = true;
    private bool _loadFailed = false;
    private int _totalEquipos = 0;
    private int _criticalAlerts = 0;
    private int _upcomingAlerts = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _loadFailed = false;
        try 
        {
            var equiposResponse = await EquipmentService.GetEquiposAsync(limit: 1000);
            _totalEquipos = equiposResponse.Total;

            _alerts = await EquipmentService.GetAlertsAsync();
            
            _criticalAlerts = _alerts.Count(a => a.Calibraciones.Any(c => c.FechaVencimiento < DateTime.Now));
            _upcomingAlerts = _alerts.Count(a => a.Calibraciones.Any(c => c.FechaVencimiento >= DateTime.Now && c.FechaVencimiento < DateTime.Now.AddDays(30)));
        } 
        catch (Exception ex)
        {
            _loadFailed = true;
            Snackbar.Add($"Error al conectar con la API: {ex.Message}", Severity.Error);
        } 
        finally 
        {
            _loading = false;
        }
    }

    private Color GetColor(string estado) => estado switch
    {
        "Activo" => Color.Success,
        "Danado" => Color.Error,
        "Mantenimiento" => Color.Warning,
        _ => Color.Default
    };

    private Color GetExpirationColor(DateTime? dueDate)
    {
        if (!dueDate.HasValue) return Color.Default;
        if (dueDate.Value < DateTime.Now) return Color.Error;
        if (dueDate.Value < DateTime.Now.AddDays(30)) return Color.Warning;
        return Color.Success;
    }
}
