@using frontend.Models
@using frontend.Services
@inject UserService UserService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            @(IsEdit ? "Editar Rol" : "Nuevo Rol")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form">
            <MudTextField T="string" Label="Nombre del Rol" @bind-Value="_roleName" 
                          Required="true" RequiredError="El nombre es obligatorio" Variant="Variant.Outlined" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="@_processing">
            @if (_processing)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Procesando...</span>
            }
            else
            {
                <span>Guardar</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Role? ExistingRole { get; set; }

    private bool IsEdit => ExistingRole != null;
    private bool _processing = false;
    private MudForm _form = null!;
    private string _roleName = string.Empty;

    protected override void OnInitialized()
    {
        if (IsEdit && ExistingRole != null)
        {
            _roleName = ExistingRole.Name;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.Validate();
        if (!_form.IsValid) return;

        _processing = true;
        try
        {
            if (IsEdit && ExistingRole != null)
            {
                await UserService.UpdateRoleAsync(ExistingRole.Id, _roleName);
                Snackbar.Add("Rol actualizado correctamente", Severity.Success);
            }
            else
            {
                await UserService.CreateRoleAsync(_roleName);
                Snackbar.Add("Rol creado correctamente", Severity.Success);
            }
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }
}
