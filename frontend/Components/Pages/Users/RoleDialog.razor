@using frontend.Models
@using frontend.Services
@inject UserService UserService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            @(IsEdit ? "Editar Rol" : "Nuevo Rol")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form">
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField T="string" Label="Nombre del Rol" @bind-Value="_roleName" 
                                  Required="true" RequiredError="El nombre es obligatorio" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12">
                    <MudSelect T="int" Label="Accesos / Páginas" MultiSelection="true" @bind-SelectedValues="_selectedPermissionIds" 
                               Variant="Variant.Outlined" HelperText="Seleccione las páginas que este rol puede ver">
                        @foreach (var perm in _permissions)
                        {
                            <MudSelectItem Value="@perm.Id">@perm.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="@_processing">
            @if (_processing)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Procesando...</span>
            }
            else
            {
                <span>Guardar</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Role? ExistingRole { get; set; }

    private bool IsEdit => ExistingRole != null;
    private bool _processing = false;
    private MudForm _form = null!;
    private string _roleName = string.Empty;
    private List<Permission> _permissions = new();
    private IEnumerable<int> _selectedPermissionIds = new HashSet<int>();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _permissions = await UserService.GetPermissionsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar permisos: {ex.Message}", Severity.Error);
        }

        if (IsEdit && ExistingRole != null)
        {
            _roleName = ExistingRole.Name;
            _selectedPermissionIds = ExistingRole.Permissions?.Select(p => p.Id).ToList() ?? new List<int>();
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.Validate();
        if (!_form.IsValid) return;

        _processing = true;
        try
        {
            var permissionIds = _selectedPermissionIds.ToList();
            if (IsEdit && ExistingRole != null)
            {
                await UserService.UpdateRoleAsync(ExistingRole.Id, _roleName, permissionIds);
                Snackbar.Add("Rol actualizado correctamente", Severity.Success);
            }
            else
            {
                await UserService.CreateRoleAsync(_roleName, permissionIds);
                Snackbar.Add("Rol creado correctamente", Severity.Success);
            }
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }
}
