@page "/usuarios"
@using frontend.Models
@using frontend.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject UserService UserService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Control de Acceso - LSMCH</PageTitle>

<div class="animate__animated animate__fadeIn">
    <div class="section-header d-flex align-center justify-space-between mb-8">
        <div>
            <MudText Typo="Typo.h4" Class="font-weight-black lsmch-title">CONTROL DE ACCESO</MudText>
            <MudText Typo="Typo.subtitle1" Class="text-secondary">Gestión de Usuarios, Roles y Permisos</MudText>
        </div>
    </div>

    <MudTabs Elevation="0" Outlined="true" Class="rounded-xl shadow-sm border border-solid border-light lsmch-glass mt-4">
        <MudTabPanel Text="Usuarios" Icon="@Icons.Material.Filled.People">
            <div class="d-flex justify-end mb-4">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd" 
                           OnClick="OpenCreateDialog" Class="rounded-pill px-6">Nuevo Usuario</MudButton>
            </div>
            <MudTable Items="@_users" Hover="true" Loading="@_loading" Elevation="0" Class="lsmch-glass-inset">
                <ToolBarContent>
                    <MudTextField @bind-Value="_searchString" Placeholder="Buscar por nombre o correo..." Adornment="Adornment.Start" 
                                  AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" Immediate="true" />
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>Foto</MudTh>
                    <MudTh>Nombre</MudTh>
                    <MudTh>Correo Electrónico</MudTh>
                    <MudTh>Rol</MudTh>
                    <MudTh>Estado</MudTh>
                    <MudTh>Acciones</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Foto">
                        <MudAvatar Size="Size.Medium" Color="Color.Primary">
                            @if (!string.IsNullOrEmpty(context.PhotoUrl))
                            {
                                <MudImage Src="@context.PhotoUrl" ObjectFit="ObjectFit.Cover" Style="width: 100%; height: 100%;" />
                            }
                            else if (!string.IsNullOrEmpty(context.FullName))
                            {
                                @GetInitials(context.FullName)
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Person" />
                            }
                        </MudAvatar>
                    </MudTd>
                    <MudTd DataLabel="Nombre">@context.FullName</MudTd>
                    <MudTd DataLabel="Email">@context.Email</MudTd>
                    <MudTd DataLabel="Rol">
                        <MudChip T="string" Color="Color.Info" Variant="Variant.Text" Size="Size.Small">@context.RoleNames</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Estado">
                        <MudChip T="bool" Color="@(context.IsActive ? Color.Success : Color.Error)" Size="Size.Small">
                            @(context.IsActive ? "Activo" : "Inactivo")
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Acciones">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Info" Size="Size.Small" OnClick="@(() => OpenEditDialog(context))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => DeleteUser(context))" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager InfoFormat="Registros por página:" RowsPerPageString="Filas:" />
                </PagerContent>
            </MudTable>
        </MudTabPanel>

        <MudTabPanel Text="Roles" Icon="@Icons.Material.Filled.AdminPanelSettings">
            <div class="d-flex justify-end mb-4">
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.AddModerator" 
                           OnClick="OpenCreateRoleDialog" Class="rounded-pill px-6">Nuevo Rol</MudButton>
            </div>
            <MudTable Items="@_roles" Hover="true" Loading="@_loadingRoles" Elevation="0" Class="lsmch-glass-inset">
                <HeaderContent>
                    <MudTh>ID</MudTh>
                    <MudTh>Nombre del Rol</MudTh>
                    <MudTh>Acciones</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="ID">@context.Id</MudTd>
                    <MudTd DataLabel="Nombre">@context.Name</MudTd>
                    <MudTd DataLabel="Acciones">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Info" Size="Size.Small" OnClick="@(() => OpenEditRoleDialog(context))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => DeleteRole(context))" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudTabPanel>
    </MudTabs>
</div>

@code {
    private List<User> _users = new();
    private List<Role> _roles = new();
    private bool _loading = true;
    private bool _loadingRoles = false;
    private string _searchString = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
        await LoadRolesAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        try { _users = await UserService.GetUsersAsync(); }
        catch (Exception ex) { Snackbar.Add($"Error al cargar usuarios: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    private async Task LoadRolesAsync()
    {
        _loadingRoles = true;
        try { _roles = await UserService.GetRolesAsync(); }
        catch (Exception ex) { Snackbar.Add($"Error al cargar roles: {ex.Message}", Severity.Error); }
        finally { _loadingRoles = false; }
    }

    private async Task OpenCreateDialog()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<UserDialog>("Registrar Nuevo Usuario", options);
        var result = await dialog.Result;
        if (result != null && !result.Canceled) await LoadDataAsync();
    }

    private async Task OpenEditDialog(User user)
    {
        var parameters = new DialogParameters<UserDialog> { { x => x.ExistingUser, user } };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<UserDialog>("Editar Usuario", parameters, options);
        var result = await dialog.Result;
        if (result != null && !result.Canceled) await LoadDataAsync();
    }

    private async Task DeleteUser(User user)
    {
        bool? result = await DialogService.ShowMessageBoxAsync("Eliminar Usuario", $"¿Está seguro de eliminar a {user.FullName}?", yesText: "Eliminar", cancelText: "Cancelar");
        if (result == true)
        {
            try
            {
                await UserService.DeleteUserAsync(user.Id);
                Snackbar.Add("Usuario eliminado", Severity.Success);
                await LoadDataAsync();
            }
            catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        }
    }

    private async Task OpenCreateRoleDialog()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<RoleDialog>("Crear Nuevo Rol", options);
        var result = await dialog.Result;
        if (result != null && !result.Canceled) await LoadRolesAsync();
    }

    private async Task OpenEditRoleDialog(Role role)
    {
        var parameters = new DialogParameters<RoleDialog> { { x => x.ExistingRole, role } };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<RoleDialog>("Editar Rol", parameters, options);
        var result = await dialog.Result;
        if (result != null && !result.Canceled) await LoadRolesAsync();
    }

    private async Task DeleteRole(Role role)
    {
        bool? result = await DialogService.ShowMessageBoxAsync("Eliminar Rol", $"¿Está seguro de eliminar el rol {role.Name}?", yesText: "Eliminar", cancelText: "Cancelar");
        if (result == true)
        {
            try
            {
                await UserService.DeleteRoleAsync(role.Id);
                Snackbar.Add("Rol eliminado", Severity.Success);
                await LoadRolesAsync();
            }
            catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        }
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
        {
            return $"{parts[0][0]}{parts[^1][0]}".ToUpper();
        }
        return name.Length >= 2 ? name[..2].ToUpper() : name.ToUpper();
    }
}
